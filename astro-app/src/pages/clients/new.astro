---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach } from '../../lib/auth';

const currentUser = await getUserFromRequest(Astro.request);

if (Astro.request.method === 'POST') {
  const { default: prisma } = await import('../../lib/prisma');
  const formData = await Astro.request.formData();

  const name = formData.get('name') as string;
  const email = formData.get('email') as string;
  const phone = formData.get('phone') as string;
  const gender = formData.get('gender') as string;
  const age = parseInt(formData.get('age') as string);
  const height = parseFloat(formData.get('height') as string);
  const currentWeight = parseFloat(formData.get('currentWeight') as string);
  const targetWeight = formData.get('targetWeight') ? parseFloat(formData.get('targetWeight') as string) : null;
  const healthNotes = formData.get('healthNotes') as string;
  const fallbackEmail = `client-${Date.now()}-${Math.floor(Math.random() * 100000)}@local.invalid`;
  const resolvedEmail = (email || '').trim() || fallbackEmail;
  const coachId = currentUser && isCoach(currentUser) ? currentUser.id : null;

  const client = await prisma.user.create({
    data: {
      name,
      email: resolvedEmail,
      password: 'temporary-password',
      role: 'student',
      coachId,
      phone: phone || null,
      gender,
      age,
      height,
      currentWeight,
      targetWeight,
      healthNotes: healthNotes || null,
      weightHistory: {
        create: { weight: currentWeight },
      },
    },
  });

  return Astro.redirect(`/clients/${client.id}`);
}
---

<MainLayout title="Yeni Müşteri" activePage="clients">
  {/* Header */}
  <header class="px-6 lg:px-8 py-5 border-b border-border-default bg-bg-secondary/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/clients" class="btn-ghost p-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div>
          <h1 class="text-2xl font-bold text-text-primary">Yeni Müşteri</h1>
          <p class="text-sm text-text-secondary mt-0.5">Yeni bir müşteri profili oluşturun</p>
        </div>
      </div>
    </div>
  </header>

  <div class="p-6 lg:p-8">
    <div class="max-w-3xl mx-auto">
      <form method="POST" id="clientForm" class="space-y-8">
        
        {/* Kişisel Bilgiler */}
        <div class="card">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-accent-primary/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-primary"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-text-primary">Kişisel Bilgiler</h2>
              <p class="text-sm text-text-muted">Müşterinin temel bilgilerini girin</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
            <div class="space-y-2">
              <label class="label" for="name">Ad Soyad <span class="text-accent-red">*</span></label>
              <input type="text" id="name" name="name" class="input-field" required placeholder="Müşterinin adı" />
            </div>
            <div class="space-y-2">
              <label class="label" for="gender">Cinsiyet <span class="text-accent-red">*</span></label>
              <div class="relative">
                <select id="gender" name="gender" class="input-field appearance-none pr-10 cursor-pointer" required>
                  <option value="" class="bg-bg-secondary">Seçin</option>
                  <option value="male" class="bg-bg-secondary">Erkek</option>
                  <option value="female" class="bg-bg-secondary">Kadın</option>
                </select>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-muted pointer-events-none"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            <div class="space-y-2">
              <label class="label" for="age">Yaş <span class="text-accent-red">*</span></label>
              <input type="number" id="age" name="age" class="input-field" required min="10" max="100" placeholder="25" />
            </div>
            <div class="space-y-2">
              <label class="label" for="email">E-posta</label>
              <input type="email" id="email" name="email" class="input-field" placeholder="ornek@mail.com" />
            </div>
            <div class="space-y-2">
              <label class="label" for="phone">Telefon</label>
              <input type="tel" id="phone" name="phone" class="input-field" placeholder="0532 xxx xx xx" />
            </div>
          </div>
        </div>

        {/* Fiziksel Bilgiler */}
        <div class="card">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-accent-cyan/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><path d="M12 22V8"/><path d="m5 12 7-4 7 4"/><path d="M12 2v2"/></svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-text-primary">Fiziksel Bilgiler</h2>
              <p class="text-sm text-text-muted">Boy, kilo ve hedef bilgilerini girin</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
            <div class="space-y-2">
              <label class="label" for="height">Boy (cm) <span class="text-accent-red">*</span></label>
              <input type="number" id="height" name="height" class="input-field" required min="100" max="250" step="0.1" placeholder="175" />
            </div>
            <div class="space-y-2">
              <label class="label" for="currentWeight">Mevcut Kilo (kg) <span class="text-accent-red">*</span></label>
              <input type="number" id="currentWeight" name="currentWeight" class="input-field" required min="30" max="300" step="0.1" placeholder="80" />
            </div>
            <div class="space-y-2">
              <label class="label" for="targetWeight">Hedef Kilo (kg)</label>
              <input type="number" id="targetWeight" name="targetWeight" class="input-field" min="30" max="300" step="0.1" placeholder="75" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="label" for="healthNotes">Sağlık Notları</label>
            <textarea id="healthNotes" name="healthNotes" class="input-field min-h-[120px] resize-y" placeholder="Sakatlık, alerji, kronik hastalık vb. bilgiler..."></textarea>
            <p class="text-xs text-text-muted">Müşterinin sağlık durumu hakkında önemli notlar</p>
          </div>
        </div>

        {/* Actions */}
        <div class="flex flex-col-reverse sm:flex-row gap-3 sm:justify-end pt-4">
          <a href="/clients" class="btn-secondary justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            İptal
          </a>
          <button type="submit" class="btn-primary justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Müşteriyi Kaydet
          </button>
        </div>
      </form>
    </div>
  </div>
</MainLayout>
