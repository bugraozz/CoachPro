---
import MainLayout from '../../layouts/MainLayout.astro';
import prisma from '../../lib/prisma';
import { getUserFromRequest, isCoach } from '../../lib/auth';

const currentUser = await getUserFromRequest(Astro.request);
if (!currentUser) {
  return Astro.redirect('/auth/login');
}

if (!isCoach(currentUser)) {
  return Astro.redirect('/dashboard');
}

const clients = await prisma.user.findMany({
  where: {
    role: 'student',
    coachId: currentUser.id,
  },
  include: {
    weightHistory: { orderBy: { date: 'desc' }, take: 1 },
    programs: { where: { status: 'active' } },
    bodyAnalyses: { orderBy: { date: 'desc' }, take: 1 },
  },
  orderBy: { createdAt: 'desc' },
});
---

<MainLayout title="Müşteriler" activePage="clients">
  {/* Header */}
  <header class="px-6 lg:px-8 py-5 border-b border-border-default bg-bg-secondary/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">Müşteriler</h1>
        <p class="text-sm text-text-secondary mt-1">Tüm müşterilerinizi yönetin ve takip edin</p>
      </div>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-text-muted"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input
            type="text"
            placeholder="Müşteri ara..."
            class="input-field pl-11 w-full sm:w-70"
            id="searchInput"
          />
        </div>
        <a href="/clients/new" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Yeni Müşteri
        </a>
      </div>
    </div>
  </header>

  <div class="p-6 lg:p-8">
    {clients.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-5" id="clientsGrid">
        {clients.map(client => (
          <a href={`/clients/${client.id}`} class="client-card card-interactive group" data-name={client.name.toLowerCase()}>
            {/* Status indicator */}
            <div class="flex items-center justify-between mb-4">
              <div class={`flex items-center gap-2 text-xs font-medium ${client.active ? 'text-accent-green' : 'text-text-muted'}`}>
                <span class={`w-2 h-2 rounded-full ${client.active ? 'bg-accent-green animate-pulse' : 'bg-text-muted'}`}></span>
                {client.active ? 'Aktif' : 'Pasif'}
              </div>
              <div class="flex gap-1.5">
                {client.programs.length > 0 && <span class="badge-success text-[10px] py-0.5">Program</span>}
                {client.bodyAnalyses.length > 0 && <span class="badge-info text-[10px] py-0.5">Analiz</span>}
              </div>
            </div>
            
            {/* Profile */}
            <div class="flex items-center gap-4 mb-5">
              <div class="w-14 h-14 rounded-2xl bg-linear-to-br from-accent-primary to-accent-purple flex items-center justify-center text-xl font-bold text-white shrink-0 overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow">
                {client.photoUrl ? (
                  <img src={client.photoUrl} alt={client.name} class="w-full h-full object-cover" />
                ) : (
                  client.name.charAt(0).toUpperCase()
                )}
              </div>
              <div class="flex flex-col min-w-0">
                <h3 class="text-base font-semibold text-text-primary truncate group-hover:text-accent-primary transition-colors">{client.name}</h3>
                <div class="text-sm text-text-secondary">
                  {client.age} yaş • {client.gender === 'male' ? 'Erkek' : 'Kadın'}
                </div>
                <div class="text-xs text-text-muted mt-0.5">{client.height} cm</div>
              </div>
            </div>
            
            {/* Stats */}
            <div class="grid grid-cols-3 gap-3 pt-4 border-t border-border-default">
              <div class="text-center">
                <div class="text-lg font-bold text-text-primary">{client.currentWeight}</div>
                <div class="text-[10px] text-text-muted uppercase tracking-wider mt-0.5">Kilo</div>
              </div>
              <div class="text-center">
                <div class={`text-lg font-bold ${client.targetWeight ? 'text-accent-cyan' : 'text-text-muted'}`}>
                  {client.targetWeight || '—'}
                </div>
                <div class="text-[10px] text-text-muted uppercase tracking-wider mt-0.5">Hedef</div>
              </div>
              <div class="text-center">
                <div class={`text-lg font-bold ${client.programs.length > 0 ? 'text-accent-green' : 'text-text-muted'}`}>
                  {client.programs.length > 0 ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="mx-auto"><polyline points="20 6 9 17 4 12"/></svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mx-auto"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  )}
                </div>
                <div class="text-[10px] text-text-muted uppercase tracking-wider mt-0.5">Program</div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="flex flex-col items-center justify-center py-20 px-4 text-center">
        <div class="w-20 h-20 rounded-3xl bg-bg-tertiary flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-text-primary mb-3">Müşteri bulunamadı</h3>
        <p class="text-text-secondary mb-8 max-w-md">İlk müşterinizi ekleyerek hemen başlayın. Müşterilerinize program, diyet ve vücut analizi yapabilirsiniz.</p>
        <a href="/clients/new" class="btn-primary text-base px-6 py-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          İlk Müşteriyi Ekle
        </a>
      </div>
    )}
  </div>

  <script is:inline>
    document.getElementById('searchInput')?.addEventListener('input', function(e) {
      const search = e.target.value.toLowerCase();
      document.querySelectorAll('.client-card').forEach(card => {
        const name = card.dataset.name;
        card.style.display = name.includes(search) ? '' : 'none';
      });
    });
  </script>
</MainLayout>
