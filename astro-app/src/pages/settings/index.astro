---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isBackofficeUser, isCoach } from '../../lib/auth';
import { retrieveSubMerchant } from '../../lib/iyzico';
import { normalizeIban, normalizeIdentityNumber, syncCoachSubMerchant, validateCoachPayoutInput } from '../../lib/iyzico-marketplace';
import prisma from '../../lib/prisma';
import { getCoachStudentPackageDiscount, setCoachStudentPackageDiscount } from '../../lib/pricing';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

const userIsCoach = isCoach(user);
const userIsBackoffice = isBackofficeUser(user);
let coachPackages: any[] = [];
let paymentHistory: any[] = [];
let backofficeCoaches: any[] = [];
let backofficeFailedTransactions: any[] = [];
let coachReferralDiscount: {
  enabled: boolean;
  amount: number;
  updatedAt: string | null;
  updatedBy: string | null;
} = { enabled: false, amount: 0, updatedAt: null, updatedBy: null };
const payoutSaved = Astro.url.searchParams.get('payoutSaved') === '1';
const payoutError = (Astro.url.searchParams.get('payoutError') || '').trim();
const discountSaved = Astro.url.searchParams.get('discountSaved') === '1';
const discountError = (Astro.url.searchParams.get('discountError') || '').trim();

const extractFailureReason = (metadata: unknown): string => {
  if (!metadata || typeof metadata !== 'object') {
    return 'Bilinmeyen hata';
  }

  const map = metadata as Record<string, unknown>;
  const candidates = [
    map.failureReason,
    map.checkoutError,
    map.error,
    map.marketplaceFallbackReason,
  ];

  for (const candidate of candidates) {
    if (typeof candidate === 'string' && candidate.trim()) {
      return candidate.trim();
    }
  }

  return 'Bilinmeyen hata';
};

if (userIsCoach && Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = (formData.get('action') as string || '').trim();

  if (action === 'save_payout_profile') {
    const subMerchantType = (formData.get('subMerchantType') as string || 'PERSONAL').trim();
    const identityNumber = (formData.get('identityNumber') as string || '').trim();
    const iban = (formData.get('iban') as string || '').trim();
    const contactPhone = (formData.get('contactPhone') as string || '').trim();
    const address = (formData.get('address') as string || '').trim();
    const city = (formData.get('city') as string || '').trim();
    const zipCode = (formData.get('zipCode') as string || '').trim();
    const taxOffice = (formData.get('taxOffice') as string || '').trim();
    const legalCompanyTitle = (formData.get('legalCompanyTitle') as string || '').trim();
    const manualSubMerchantKey = (formData.get('manualSubMerchantKey') as string || '').trim();
    const manualSubMerchantExternalId = (formData.get('manualSubMerchantExternalId') as string || '').trim();

    const validationError = validateCoachPayoutInput({
      subMerchantType,
      identityNumber,
      iban,
      address,
      city,
      zipCode,
      taxOffice: taxOffice || null,
      legalCompanyTitle: legalCompanyTitle || null,
    });

    if (validationError) {
      return Astro.redirect(`/settings?tab=account&payoutError=${encodeURIComponent(validationError)}`);
    }

    if (manualSubMerchantKey && !manualSubMerchantExternalId) {
      return Astro.redirect('/settings?tab=account&payoutError=Manuel anahtar kullanimi icin SubMerchantExternalId zorunludur.');
    }

    let syncResult: {
      ok: boolean;
      error?: string;
      subMerchantKey?: string;
      subMerchantExternalId?: string;
      subMerchantStatus?: string;
    };

    if (manualSubMerchantKey && manualSubMerchantExternalId) {
      const retrieved = await retrieveSubMerchant({
        locale: 'tr',
        conversationId: `coach-manual-link-${user.id}`,
        subMerchantExternalId: manualSubMerchantExternalId,
      }).catch(() => null);

      const retrievedStatus = String((retrieved as Record<string, unknown> | null)?.status || '').toLowerCase();
      const retrievedSubMerchantKey = String((retrieved as Record<string, unknown> | null)?.subMerchantKey || '').trim();

      if (!retrieved || retrievedStatus !== 'success') {
        syncResult = {
          ok: false,
          error: String((retrieved as Record<string, unknown> | null)?.errorMessage || 'Alt uye isyeri bilgisi dogrulanamadi.'),
        };
      } else if (retrievedSubMerchantKey && retrievedSubMerchantKey !== manualSubMerchantKey) {
        syncResult = {
          ok: false,
          error: 'Girilen SubMerchantKey, verilen external id ile eslesmiyor.',
        };
      } else {
        syncResult = {
          ok: true,
          subMerchantKey: manualSubMerchantKey,
          subMerchantExternalId: manualSubMerchantExternalId,
          subMerchantStatus: String((retrieved as Record<string, unknown> | null)?.subMerchantStatus || 'active'),
        };
      }
    } else {
      syncResult = await syncCoachSubMerchant({
        coachId: user.id,
        email: user.email,
        phone: contactPhone || user.phone,
        fullName: user.name,
        subMerchantType: subMerchantType === 'PRIVATE_COMPANY' ? 'PRIVATE_COMPANY' : 'PERSONAL',
        identityNumber,
        iban,
        address,
        city,
        zipCode,
        taxOffice: taxOffice || null,
        legalCompanyTitle: legalCompanyTitle || null,
        existingSubMerchantKey: user.iyzicoSubMerchantKey || null,
        existingExternalId: user.iyzicoSubMerchantExternalId || null,
      });
    }

    if (!syncResult.ok || !syncResult.subMerchantKey) {
      await prisma.user.update({
        where: { id: user.id },
        data: {
          iyzicoSubMerchantType: subMerchantType,
          iyzicoIdentityNumber: normalizeIdentityNumber(identityNumber),
          iyzicoIban: normalizeIban(iban),
          iyzicoAddress: address,
          iyzicoCity: city,
          iyzicoZipCode: zipCode,
          iyzicoTaxOffice: taxOffice || null,
          iyzicoLegalCompanyTitle: legalCompanyTitle || null,
          iyzicoLastError: syncResult.error || 'Iyzico senkronizasyon hatasi.',
          iyzicoLastSyncAt: new Date(),
          phone: contactPhone || user.phone,
        },
      });

      return Astro.redirect(`/settings?tab=account&payoutError=${encodeURIComponent(syncResult.error || 'Iyzico kaydi olusturulamadi.')}`);
    }

    const nameParts = user.name.trim().split(/\s+/).filter(Boolean);
    const contactName = nameParts[0] || 'Coach';
    const contactSurname = nameParts.length > 1 ? nameParts.slice(1).join(' ') : 'User';

    await prisma.user.update({
      where: { id: user.id },
      data: {
        phone: contactPhone || user.phone,
        iyzicoSubMerchantType: subMerchantType,
        iyzicoIdentityNumber: normalizeIdentityNumber(identityNumber),
        iyzicoIban: normalizeIban(iban),
        iyzicoAddress: address,
        iyzicoCity: city,
        iyzicoZipCode: zipCode,
        iyzicoTaxOffice: taxOffice || null,
        iyzicoLegalCompanyTitle: legalCompanyTitle || null,
        iyzicoContactName: contactName,
        iyzicoContactSurname: contactSurname,
        iyzicoSubMerchantKey: syncResult.subMerchantKey,
        iyzicoSubMerchantExternalId: syncResult.subMerchantExternalId || user.iyzicoSubMerchantExternalId || `coach_${user.id}`,
        iyzicoSubMerchantStatus: syncResult.subMerchantStatus || 'active',
        iyzicoPayoutReadyAt: new Date(),
        iyzicoLastSyncAt: new Date(),
        iyzicoLastError: null,
      },
    });

    return Astro.redirect('/settings?tab=account&payoutSaved=1');
  }

  if (action === 'create_package') {
    const name = (formData.get('name') as string || '').trim();
    const description = (formData.get('description') as string || '').trim();
    const price = parseInt((formData.get('price') as string || '0').trim(), 10);
    const durationWeeks = parseInt((formData.get('durationWeeks') as string || '4').trim(), 10);

    if (name && price > 0 && durationWeeks > 0) {
      await prisma.coachPackage.create({
        data: {
          coachId: user.id,
          name,
          description: description || null,
          price,
          durationWeeks,
          isActive: true,
        },
      });
    }
  }

  if (action === 'save_referral_discount') {
    const enabled = (formData.get('enabled') as string || '').trim() === 'true';
    const amount = parseInt((formData.get('amount') as string || '0').trim(), 10);

    if (Number.isNaN(amount) || amount < 0) {
      return Astro.redirect('/settings?tab=account&discountError=Indirim%20tutari%20gecersiz.');
    }

    await setCoachStudentPackageDiscount(user.id, {
      enabled,
      amount,
      updatedBy: user.id,
    });

    return Astro.redirect('/settings?tab=account&discountSaved=1');
  }

  if (action === 'toggle_package') {
    const packageId = (formData.get('packageId') as string || '').trim();
    const currentState = (formData.get('currentState') as string || '').trim();
    const isCurrentlyActive = currentState === 'active';

    if (packageId) {
      await prisma.coachPackage.updateMany({
        where: { id: packageId, coachId: user.id },
        data: { isActive: !isCurrentlyActive },
      });
    }
  }

  if (action === 'update_package') {
    const packageId = (formData.get('packageId') as string || '').trim();
    const name = (formData.get('name') as string || '').trim();
    const description = (formData.get('description') as string || '').trim();
    const price = parseInt((formData.get('price') as string || '0').trim(), 10);
    const durationWeeks = parseInt((formData.get('durationWeeks') as string || '0').trim(), 10);
    const isActive = (formData.get('isActive') as string || '').trim() === 'true';

    if (packageId && name && price > 0 && durationWeeks > 0) {
      await prisma.coachPackage.updateMany({
        where: { id: packageId, coachId: user.id },
        data: {
          name,
          description: description || null,
          price,
          durationWeeks,
          isActive,
        },
      });
    }
  }

  if (action === 'delete_package') {
    const packageId = (formData.get('packageId') as string || '').trim();

    if (packageId) {
      await prisma.coachPackage.deleteMany({
        where: { id: packageId, coachId: user.id },
      });
    }
  }

  return Astro.redirect('/settings?tab=account');
}

if (userIsCoach) {
  coachPackages = await prisma.coachPackage.findMany({
    where: { coachId: user.id },
    orderBy: [{ isActive: 'desc' }, { createdAt: 'desc' }],
  });

  coachReferralDiscount = await getCoachStudentPackageDiscount(user.id);
}

if (userIsBackoffice) {
  backofficeCoaches = await prisma.user.findMany({
    where: { role: 'coach' },
    select: {
      id: true,
      name: true,
      email: true,
      subscriptionStatus: true,
      iyzicoSubMerchantStatus: true,
      iyzicoSubMerchantKey: true,
      iyzicoPayoutReadyAt: true,
      iyzicoLastSyncAt: true,
      iyzicoLastError: true,
      createdAt: true,
    },
    orderBy: { createdAt: 'desc' },
    take: 150,
  });

  backofficeFailedTransactions = await prisma.paymentTransaction.findMany({
    where: {
      type: 'student_package',
      status: 'failed',
    },
    select: {
      id: true,
      amount: true,
      createdAt: true,
      metadata: true,
      payer: {
        select: {
          id: true,
          name: true,
          email: true,
        },
      },
      coach: {
        select: {
          id: true,
          name: true,
          email: true,
        },
      },
    },
    orderBy: { createdAt: 'desc' },
    take: 50,
  });
}

paymentHistory = await prisma.paymentTransaction.findMany({
  where: userIsCoach
    ? {
        OR: [{ payerId: user.id }, { coachId: user.id }],
      }
    : {
        OR: [{ payerId: user.id }, { studentId: user.id }],
      },
  include: {
    payer: {
      select: {
        id: true,
        name: true,
      },
    },
    student: {
      select: {
        id: true,
        name: true,
      },
    },
    coachPackage: {
      select: {
        id: true,
        name: true,
      },
    },
  },
  orderBy: { createdAt: 'desc' },
  take: 40,
});

const paymentSummary = paymentHistory.reduce(
  (acc, payment) => {
    acc.total += 1;

    if (payment.status === 'paid') {
      acc.paid += 1;
      acc.revenue += Number(payment.amount || 0);
    }

    if (payment.status === 'failed') {
      acc.failed += 1;
      const metadata = typeof payment.metadata === 'object' && payment.metadata ? payment.metadata as Record<string, unknown> : null;
      const reason = extractFailureReason(metadata);
      acc.failureReasons[reason] = (acc.failureReasons[reason] || 0) + 1;
    }

    if (payment.status === 'pending') {
      acc.pending += 1;
    }

    const metadata = typeof payment.metadata === 'object' && payment.metadata ? payment.metadata as Record<string, unknown> : null;
    if (metadata && metadata.retryOfTransactionId) {
      acc.retries += 1;
    }

    return acc;
  },
  {
    total: 0,
    paid: 0,
    failed: 0,
    pending: 0,
    retries: 0,
    revenue: 0,
    failureReasons: {} as Record<string, number>,
  },
);

const topFailureReasons = (Object.entries(paymentSummary.failureReasons) as Array<[string, number]>)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3);

const backofficeSummary = backofficeCoaches.reduce(
  (acc, coach) => {
    acc.total += 1;
    if (coach.iyzicoPayoutReadyAt) {
      acc.payoutReady += 1;
    } else {
      acc.payoutMissing += 1;
    }

    if (coach.iyzicoLastError) {
      acc.syncError += 1;
      const reason = coach.iyzicoLastError.trim();
      acc.errorReasons[reason] = (acc.errorReasons[reason] || 0) + 1;
    }

    if (coach.subscriptionStatus === 'active') {
      acc.subscriptionActive += 1;
    }

    return acc;
  },
  {
    total: 0,
    payoutReady: 0,
    payoutMissing: 0,
    syncError: 0,
    subscriptionActive: 0,
    errorReasons: {} as Record<string, number>,
  },
);

const topSyncErrorReasons = (Object.entries(backofficeSummary.errorReasons) as Array<[string, number]>)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const coachesMissingPayoutSetup = backofficeCoaches
  .filter((coach) => !coach.iyzicoPayoutReadyAt)
  .slice(0, 25);

type MarketplaceActivationItem = {
  coachId: string;
  coachName: string;
  coachEmail: string;
  failedCount: number;
  latestFailedAt: Date;
  reason: string;
};

const marketplaceActivationQueue: MarketplaceActivationItem[] = (Object.values(
  backofficeFailedTransactions.reduce((acc, tx) => {
    const reason = extractFailureReason(tx.metadata).toLowerCase();
    const metadata = typeof tx.metadata === 'object' && tx.metadata ? tx.metadata as Record<string, unknown> : null;
    const isMarketplaceFallback =
      reason.includes('submerchant') ||
      Boolean(metadata && metadata.marketplaceFallbackUsed);

    const coachId = tx.coach?.id;
    if (!isMarketplaceFallback || !coachId) {
      return acc;
    }

    if (!acc[coachId]) {
      acc[coachId] = {
        coachId,
        coachName: tx.coach?.name || '-',
        coachEmail: tx.coach?.email || '-',
        failedCount: 0,
        latestFailedAt: tx.createdAt,
        reason: extractFailureReason(tx.metadata),
      };
    }

    acc[coachId].failedCount += 1;
    if (new Date(tx.createdAt) > new Date(acc[coachId].latestFailedAt)) {
      acc[coachId].latestFailedAt = tx.createdAt;
      acc[coachId].reason = extractFailureReason(tx.metadata);
    }

    return acc;
  }, {} as Record<string, MarketplaceActivationItem>),
) as MarketplaceActivationItem[])
  .sort((a: MarketplaceActivationItem, b: MarketplaceActivationItem) => {
    const failedDiff = b.failedCount - a.failedCount;
    if (failedDiff !== 0) return failedDiff;
    return new Date(b.latestFailedAt).getTime() - new Date(a.latestFailedAt).getTime();
  })
  .slice(0, 25);
---

<MainLayout title="Ayarlar" activePage="settings">
  <!-- Header -->
  <header class="section-header">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="animate-in">
        <h1>Ayarlar</h1>
        <p>Hesap ve profil ayarlarınızı yönetin</p>
      </div>
    </div>
  </header>

  <div class="page-content">
    <!-- Tab Navigation -->
    <div class="flex flex-wrap gap-1 p-1 rounded-xl bg-bg-secondary border border-border-default mb-8 max-w-5xl mx-auto">
      <button data-tab="profile" class="tab-btn active flex-1 py-2.5 px-4 rounded-lg text-sm font-medium transition-all">Profil</button>
      <button data-tab="security" class="tab-btn flex-1 py-2.5 px-4 rounded-lg text-sm font-medium transition-all">Güvenlik</button>
      <button data-tab="account" class="tab-btn flex-1 py-2.5 px-4 rounded-lg text-sm font-medium transition-all">Hesap</button>
      {userIsBackoffice && <button data-tab="backoffice" class="tab-btn flex-1 py-2.5 px-4 rounded-lg text-sm font-medium transition-all">Backoffice</button>}
    </div>

    <!-- Profile Tab -->
    <div id="tab-profile" class="tab-content">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Profile Card -->
        <div class="lg:col-span-1">
          <div class="card text-center">
            <div class="w-24 h-24 rounded-full bg-linear-to-br from-accent-purple to-accent-primary flex items-center justify-center text-3xl font-bold text-white mx-auto mb-4 shadow-lg">
              {user.name.charAt(0).toUpperCase()}
            </div>
            <h3 class="text-lg font-semibold text-text-primary">{user.name}</h3>
            <p class="text-sm text-text-muted mt-1">{user.email}</p>
            <div class="mt-3">
              <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium ${userIsCoach ? 'bg-accent-primary/15 text-accent-primary' : 'bg-accent-cyan/15 text-accent-cyan'}`}>
                <span class={`w-2 h-2 rounded-full ${userIsCoach ? 'bg-accent-primary' : 'bg-accent-cyan'}`}></span>
                {userIsCoach ? 'Eğitmen' : 'Öğrenci'}
              </span>
            </div>
            {userIsCoach && user.referralCode && (
              <div class="mt-5 pt-5 border-t border-border-default">
                <p class="text-xs text-text-muted uppercase tracking-wider mb-2">Referans Kodu</p>
                <div class="flex items-center justify-center gap-2">
                  <code class="text-lg font-bold font-mono text-accent-cyan tracking-widest">{user.referralCode}</code>
                  <button onclick={`navigator.clipboard.writeText('${user.referralCode}'); showToast('Referans kodu kopyalandı')`} class="p-1.5 rounded-lg hover:bg-bg-tertiary transition-colors" title="Kopyala">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-muted"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                  </button>
                </div>
              </div>
            )}
            <div class="mt-5 pt-5 border-t border-border-default text-left space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-xs text-text-muted">Kayıt Tarihi</span>
                <span class="text-sm text-text-secondary">{new Date(user.createdAt).toLocaleDateString('tr-TR')}</span>
              </div>
              {userIsCoach && (
                <div class="flex items-center justify-between">
                  <span class="text-xs text-text-muted">Abonelik</span>
                  <span class={`text-sm font-medium ${user.subscriptionStatus === 'active' ? 'text-accent-green' : 'text-accent-red'}`}>
                    {user.subscriptionStatus === 'active' ? 'Aktif' : 'Pasif'}
                  </span>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- Profile Form -->
        <div class="lg:col-span-2">
          <div class="card">
            <h3 class="text-lg font-semibold text-text-primary mb-1">Kişisel Bilgiler</h3>
            <p class="text-sm text-text-muted mb-6">Profil bilgilerinizi güncelleyin</p>

            <form id="profileForm" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="label block mb-2">Ad Soyad</label>
                  <input type="text" name="name" value={user.name} class="input-field" required />
                </div>
                <div>
                  <label class="label block mb-2">E-posta</label>
                  <input type="email" value={user.email} class="input-field opacity-60 cursor-not-allowed" disabled />
                  <p class="text-xs text-text-muted mt-1">E-posta değiştirilemez</p>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="label block mb-2">Telefon</label>
                  <input type="tel" name="phone" value={user.phone || ''} placeholder="05XX XXX XX XX" class="input-field" />
                </div>
                <div>
                  <label class="label block mb-2">Cinsiyet</label>
                  <select name="gender" class="input-field">
                    <option value="">Seçiniz</option>
                    <option value="male" selected={user.gender === 'male'}>Erkek</option>
                    <option value="female" selected={user.gender === 'female'}>Kadın</option>
                  </select>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="label block mb-2">Yaş</label>
                  <input type="number" name="age" value={user.age || ''} placeholder="25" min="10" max="100" class="input-field" />
                </div>
                <div>
                  <label class="label block mb-2">Boy (cm)</label>
                  <input type="number" name="height" value={user.height || ''} placeholder="175" step="0.1" class="input-field" />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="label block mb-2">Mevcut Kilo (kg)</label>
                  <input type="number" name="currentWeight" value={user.currentWeight || ''} placeholder="75" step="0.1" class="input-field" />
                </div>
                <div>
                  <label class="label block mb-2">Hedef Kilo (kg)</label>
                  <input type="number" name="targetWeight" value={user.targetWeight || ''} placeholder="70" step="0.1" class="input-field" />
                </div>
              </div>

              <div>
                <label class="label block mb-2">Sağlık Notları</label>
                <textarea name="healthNotes" rows="3" placeholder="Varsa sağlık sorunları, alerjiler, sakatlıklar..." class="input-field resize-none">{user.healthNotes || ''}</textarea>
              </div>

              <div class="flex items-center justify-end gap-3 pt-2">
                <div id="profileStatus" class="text-sm font-medium"></div>
                <button type="submit" id="profileSaveBtn" class="btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                  Kaydet
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
     </div>
    </div>

    <!-- Security Tab -->
    <div id="tab-security" class="tab-content hidden">
      <div class="max-w-5xl mx-auto">
        <div class="card">
          <h3 class="text-lg font-semibold text-text-primary mb-1">Şifre Değiştir</h3>
          <p class="text-sm text-text-muted mb-6">Hesap güvenliğiniz için güçlü bir şifre kullanın</p>

          <form id="passwordForm" class="space-y-5">
            <div>
              <label class="label block mb-2">Mevcut Şifre</label>
