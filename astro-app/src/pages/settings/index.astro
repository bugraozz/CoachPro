              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-border-default/60">
                    <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Tarih</th>
                    <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Tip</th>
                    <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Paket</th>
                    {userIsCoach && <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Odeyen</th>}
                    <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Tutar</th>
                    <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Durum</th>
                  </tr>
                </thead>
                <tbody>
                  {paymentHistory.map((payment) => (
                    <tr class="border-b border-border-default/40">
                      <td class="py-3 px-2 text-text-secondary">{new Date(payment.createdAt).toLocaleString('tr-TR')}</td>
                      <td class="py-3 px-2 text-text-secondary">
                        {payment.type === 'coach_subscription' ? 'Koç Abonelik' : 'Ogrenci Paket'}
                      </td>
                      <td class="py-3 px-2 text-text-secondary">{payment.coachPackage?.name || 'Abonelik'}</td>
                      {userIsCoach && (
                        <td class="py-3 px-2 text-text-secondary">{payment.payer?.name || '-'}</td>
                      )}
                      <td class="py-3 px-2 font-medium text-text-primary">₺{payment.amount}</td>
                      <td class="py-3 px-2">
                        <span
                          class={`badge ${payment.status === 'paid' ? 'badge-success' : ''}`}
                          style={payment.status === 'paid' ? '' : 'background:rgba(239,68,68,0.15);color:var(--color-accent-red);border:1px solid rgba(239,68,68,0.2)'}
                        >
                          {payment.status === 'paid' ? 'Basarili' : payment.status === 'pending' ? 'Bekliyor' : 'Basarisiz'}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="p-4 rounded-xl bg-bg-tertiary/30 border border-border-default text-sm text-text-muted">
              Henuz kayitli bir odeme islemi bulunmuyor.
            </div>
          )}
        </div>

        <!-- Danger Zone -->
        <div class="card border-accent-red/20">
          <h3 class="text-lg font-semibold text-accent-red mb-1">Tehlikeli Bölge</h3>
          <p class="text-sm text-text-muted mb-6">Bu işlemler geri alınamaz</p>
          
          <div class="flex items-center justify-between p-4 rounded-xl bg-accent-red/5 border border-accent-red/10">
            <div>
              <span class="text-sm font-medium text-text-primary">Hesabı Sil</span>
              <p class="text-xs text-text-muted mt-0.5">Tüm verileriniz kalıcı olarak silinir</p>
            </div>
            <button class="px-4 py-2 rounded-lg text-sm font-medium bg-accent-red/10 text-accent-red border border-accent-red/20 hover:bg-accent-red/20 transition-colors" onclick="alert('Bu özellik henüz aktif değil.')">
              Hesabı Sil
            </button>
          </div>
        </div>
      </div>
    </div>

    {userIsBackoffice && (
      <div id="tab-backoffice" class="tab-content hidden">
        <div class="space-y-6">
          <div class="card">
            <h3 class="text-lg font-semibold text-text-primary mb-1">Payout Onboarding Durumu</h3>
            <p class="text-sm text-text-muted mb-6">Tum egitmenlerin Iyzico payout hazirlik ve senkronizasyon durumlari.</p>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
              <div class="p-3 rounded-xl border border-border-default bg-bg-tertiary/30">
                <p class="text-xs text-text-muted">Toplam Egitmen</p>
                <p class="text-lg font-semibold text-text-primary mt-1">{backofficeSummary.total}</p>
              </div>
              <div class="p-3 rounded-xl border border-border-default bg-accent-green/5">
                <p class="text-xs text-text-muted">Payout Hazir</p>
                <p class="text-lg font-semibold text-accent-green mt-1">{backofficeSummary.payoutReady}</p>
              </div>
              <div class="p-3 rounded-xl border border-border-default bg-accent-red/5">
                <p class="text-xs text-text-muted">Payout Eksik</p>
                <p class="text-lg font-semibold text-accent-red mt-1">{backofficeSummary.payoutMissing}</p>
              </div>
              <div class="p-3 rounded-xl border border-border-default bg-accent-orange/5">
                <p class="text-xs text-text-muted">Senkron Hatasi</p>
                <p class="text-lg font-semibold text-accent-orange mt-1">{backofficeSummary.syncError}</p>
              </div>
            </div>

            {topSyncErrorReasons.length > 0 ? (
              <div class="mb-6 p-4 rounded-xl border border-border-default bg-bg-tertiary/20">
                <p class="text-xs text-text-muted mb-2">En Sik Senkronizasyon Hata Nedenleri</p>
                <div class="flex flex-wrap gap-2">
                  {topSyncErrorReasons.map(([reason, count]) => (
                    <span class="px-2 py-1 rounded-md text-xs bg-accent-red/10 border border-accent-red/20 text-accent-red">
                      {reason} ({count})
                    </span>
                  ))}
                </div>
              </div>
            ) : (
              <div class="mb-6 p-4 rounded-xl border border-border-default bg-accent-green/5 text-sm text-text-secondary">
                Kayitli payout senkron hatasi bulunmuyor.
              </div>
            )}

            <div class="mb-6 p-4 rounded-xl border border-border-default bg-bg-tertiary/20">
              <div class="flex items-center justify-between gap-3 mb-3">
                <p class="text-sm font-semibold text-text-primary">Operasyon Aksiyon Listesi</p>
                <span class="text-xs text-text-muted">
                  Toplam aksiyon: {coachesMissingPayoutSetup.length + marketplaceActivationQueue.length}
                </span>
              </div>

              <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <div class="p-3 rounded-lg border border-accent-red/20 bg-accent-red/5">
                  <p class="text-xs uppercase tracking-wider text-accent-red mb-2">Payout Setup Eksik</p>
                  {coachesMissingPayoutSetup.length > 0 ? (
                    <div class="space-y-2 max-h-52 overflow-y-auto pr-1">
                      {coachesMissingPayoutSetup.map((coach) => (
                        <div class="text-xs text-text-secondary border border-border-default rounded-md px-2 py-2 bg-bg-secondary/40">
                          <p class="font-medium text-text-primary">{coach.name}</p>
                          <p>{coach.email}</p>
                          <p class="text-text-muted mt-1">Aksiyon: IBAN/KYC formunu tamamlat ve Iyzico senkronunu yenile.</p>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <p class="text-xs text-text-secondary">Payout setup bekleyen egitmen yok.</p>
                  )}
                </div>

                <div class="p-3 rounded-lg border border-accent-orange/20 bg-accent-orange/5">
                  <p class="text-xs uppercase tracking-wider text-accent-orange mb-2">Marketplace Aktivasyon Kuyrugu</p>
                  {marketplaceActivationQueue.length > 0 ? (
                    <div class="space-y-2 max-h-52 overflow-y-auto pr-1">
                      {marketplaceActivationQueue.map((item: MarketplaceActivationItem) => (
                        <div class="text-xs text-text-secondary border border-border-default rounded-md px-2 py-2 bg-bg-secondary/40">
                          <p class="font-medium text-text-primary">{item.coachName}</p>
                          <p>{item.coachEmail}</p>
                          <p class="mt-1">Fallback: {item.failedCount} odeme</p>
                          <p class="text-text-muted">Son hata: {item.reason}</p>
                          <p class="text-text-muted">Aksiyon: Iyzico hesabinda marketplace yetkisini actir.</p>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <p class="text-xs text-text-secondary">Marketplace aktivasyon bekleyen kayit yok.</p>
                  )}
                </div>
              </div>
            </div>

            {backofficeCoaches.length > 0 ? (
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-border-default/60">
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Egitmen</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Abonelik</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Payout</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">SubMerchant</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Son Senkron</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Son Hata</th>
                    </tr>
                  </thead>
                  <tbody>
                    {backofficeCoaches.map((coach) => (
                      <tr class="border-b border-border-default/40 align-top">
                        <td class="py-3 px-2 text-text-secondary">
                          <div class="font-medium text-text-primary">{coach.name}</div>
                          <div class="text-xs text-text-muted">{coach.email}</div>
                        </td>
                        <td class="py-3 px-2 text-text-secondary">{coach.subscriptionStatus || 'pending'}</td>
                        <td class="py-3 px-2">
                          <span
                            class={`badge ${coach.iyzicoPayoutReadyAt ? 'badge-success' : ''}`}
                            style={coach.iyzicoPayoutReadyAt ? '' : 'background:rgba(239,68,68,0.15);color:var(--color-accent-red);border:1px solid rgba(239,68,68,0.2)'}
                          >
                            {coach.iyzicoPayoutReadyAt ? 'Hazir' : 'Eksik'}
                          </span>
                        </td>
                        <td class="py-3 px-2 text-text-secondary">{coach.iyzicoSubMerchantKey || '-'}</td>
                        <td class="py-3 px-2 text-text-secondary">{coach.iyzicoLastSyncAt ? new Date(coach.iyzicoLastSyncAt).toLocaleString('tr-TR') : '-'}</td>
                        <td class="py-3 px-2 text-xs text-accent-red max-w-sm wrap-break-word">{coach.iyzicoLastError || '-'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="p-4 rounded-xl bg-bg-tertiary/30 border border-border-default text-sm text-text-muted">
                Backoffice listesi icin egitmen kaydi bulunmuyor.
              </div>
            )}
          </div>

          <div class="card">
            <h3 class="text-lg font-semibold text-text-primary mb-1">Son Basarisiz Ogrenci Odemeleri</h3>
            <p class="text-sm text-text-muted mb-6">Payout veya checkout kaynakli basarisiz ogrenci odeme denemeleri.</p>

            {backofficeFailedTransactions.length > 0 ? (
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-border-default/60">
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Tarih</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Ogrenci</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Egitmen</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Tutar</th>
                      <th class="text-left py-3 px-2 text-xs uppercase tracking-wider text-text-muted">Hata Nedeni</th>
                    </tr>
                  </thead>
                  <tbody>
                    {backofficeFailedTransactions.map((tx) => (
                      <tr class="border-b border-border-default/40 align-top">
                        <td class="py-3 px-2 text-text-secondary">{new Date(tx.createdAt).toLocaleString('tr-TR')}</td>
                        <td class="py-3 px-2 text-text-secondary">{tx.payer?.name || '-'}</td>
                        <td class="py-3 px-2 text-text-secondary">{tx.coach?.name || '-'}</td>
                        <td class="py-3 px-2 font-medium text-text-primary">₺{tx.amount}</td>
                        <td class="py-3 px-2 text-xs text-accent-red max-w-sm wrap-break-word">{extractFailureReason(tx.metadata)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="p-4 rounded-xl bg-bg-tertiary/30 border border-border-default text-sm text-text-muted">
                Son donemde basarisiz ogrenci odemesi kaydi bulunmuyor.
              </div>
            )}
          </div>
        </div>
      </div>
    )}
  </div>

  <style>
    .tab-btn {
      color: var(--color-text-muted);
    }
    .tab-btn:hover {
      color: var(--color-text-primary);
      background-color: var(--color-bg-tertiary);
    }
    .tab-btn.active {
      background-color: var(--color-accent-primary);
      color: white;
      box-shadow: var(--shadow-md);
    }
  </style>

  <script is:inline>
    // Tab navigation
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    function activateTab(tab) {
      tabBtns.forEach(b => b.classList.remove('active'));
      tabContents.forEach(c => c.classList.add('hidden'));

      document.querySelector(`.tab-btn[data-tab="${tab}"]`)?.classList.add('active');
      document.getElementById('tab-' + tab)?.classList.remove('hidden');
    }

    const tabFromQuery = new URLSearchParams(window.location.search).get('tab');
    if (tabFromQuery && document.getElementById('tab-' + tabFromQuery)) {
      activateTab(tabFromQuery);
    }
    
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;

        activateTab(tab);

        const url = new URL(window.location.href);
        url.searchParams.set('tab', tab);
        window.history.replaceState({}, '', url);
      });
    });

    // Toggle password visibility
    document.querySelectorAll('.toggle-password').forEach(btn => {
      btn.addEventListener('click', () => {
        const input = btn.parentElement.querySelector('input');
        if (input.type === 'password') {
          input.type = 'text';
        } else {
          input.type = 'password';
        }
      });
    });

    // Toggle package edit forms
    document.querySelectorAll('.toggle-edit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-edit-target');
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) return;

        target.classList.toggle('hidden');
      });
    });

    // Password strength meter
    const newPasswordInput = document.querySelector('input[name="newPassword"]');
    const strengthBar = document.getElementById('passwordStrength');
    const strengthText = document.getElementById('strengthText');
    const bars = [document.getElementById('str1'), document.getElementById('str2'), document.getElementById('str3'), document.getElementById('str4')];

    newPasswordInput?.addEventListener('input', (e) => {
      const val = e.target.value;
      if (val.length === 0) {
        strengthBar.classList.add('hidden');
        return;
      }
      strengthBar.classList.remove('hidden');

      let score = 0;
      if (val.length >= 6) score++;
      if (val.length >= 10) score++;
      if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
      if (/[0-9]/.test(val) || /[^A-Za-z0-9]/.test(val)) score++;

      const colors = ['bg-accent-red', 'bg-accent-orange', 'bg-accent-yellow', 'bg-accent-green'];
      const labels = ['Zayıf', 'Orta', 'İyi', 'Güçlü'];

      bars.forEach((bar, i) => {
        bar.className = 'h-1 flex-1 rounded-full transition-colors';
        if (i < score) {
          bar.classList.add(colors[score - 1]);
        } else {
          bar.classList.add('bg-bg-tertiary');
        }
      });
      strengthText.textContent = labels[score - 1] || 'Çok zayıf';
      strengthText.className = `text-xs ${score >= 3 ? 'text-accent-green' : score >= 2 ? 'text-accent-yellow' : 'text-accent-red'}`;
    });

    // Profile form submit
    document.getElementById('profileForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const btn = document.getElementById('profileSaveBtn');
      const status = document.getElementById('profileStatus');
      
      btn.disabled = true;
      btn.textContent = 'Kaydediliyor...';

      const data = {
        name: form.name.value,
        phone: form.phone.value,
        gender: form.gender.value,
        age: form.age.value,
        height: form.height.value,
        currentWeight: form.currentWeight.value,
        targetWeight: form.targetWeight.value,
        healthNotes: form.healthNotes.value,
      };

      try {
        const res = await fetch('/api/user/update-profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();
        
        if (res.ok) {
          status.textContent = 'Kaydedildi!';
          status.className = 'text-sm font-medium text-accent-green';
          if (typeof showToast === 'function') showToast('Profil güncellendi');
          setTimeout(() => { status.textContent = ''; }, 3000);
        } else {
          status.textContent = result.error || 'Hata oluştu';
          status.className = 'text-sm font-medium text-accent-red';
        }
      } catch (err) {
        status.textContent = 'Bağlantı hatası';
        status.className = 'text-sm font-medium text-accent-red';
      }

      btn.disabled = false;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Kaydet`;
    });

    // Password form submit
    document.getElementById('passwordForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const btn = document.getElementById('passwordSaveBtn');
      const status = document.getElementById('passwordStatus');
      
      btn.disabled = true;
      btn.textContent = 'Değiştiriliyor...';

      const data = {
        currentPassword: form.currentPassword.value,
        newPassword: form.newPassword.value,
        confirmPassword: form.confirmPassword.value,
      };

      try {
        const res = await fetch('/api/user/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok) {
          status.textContent = 'Şifre değiştirildi!';
          status.className = 'text-sm font-medium text-accent-green';
          if (typeof showToast === 'function') showToast('Şifre başarıyla değiştirildi');
          form.reset();
          strengthBar.classList.add('hidden');
          setTimeout(() => { status.textContent = ''; }, 3000);
        } else {
          status.textContent = result.error || 'Hata oluştu';
          status.className = 'text-sm font-medium text-accent-red';
        }
      } catch (err) {
        status.textContent = 'Bağlantı hatası';
        status.className = 'text-sm font-medium text-accent-red';
      }

      btn.disabled = false;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Şifre Değiştir`;
    });
  </script>
</MainLayout>
