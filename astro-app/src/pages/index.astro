      </div>
    </div>
  </section>

  <!-- For Coaches & Students Section -->
  <section class="py-20 px-6 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-50 border border-red-200 text-red-600 text-xs font-medium mb-4">KİMLER İÇİN?</div>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Eğitmenler ve Öğrenciler İçin</h2>
        <p class="text-gray-600 max-w-xl mx-auto">Her iki taraf için de özel tasarlanmış araçlar</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- For Coaches -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition-all">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-600"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900">Eğitmenler İçin</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <span class="font-semibold text-gray-900">Öğrenci Yönetim Paneli</span>
                <p class="text-gray-500 text-sm mt-0.5">Tüm öğrencilerinizi tek panelden yönetin, ilerlemelerini takip edin</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <span class="font-semibold text-gray-900">Program & Diyet Oluşturucu</span>
                <p class="text-gray-500 text-sm mt-0.5">Haftalık antrenman programları ve makro hedefli diyet planları hazırlayın</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <span class="font-semibold text-gray-900">Referans Kodu Sistemi</span>
                <p class="text-gray-500 text-sm mt-0.5">Benzersiz kodunuzu paylaşın, öğrenciler anında size bağlansın</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <span class="font-semibold text-gray-900">AI Vücut Analizi</span>
                <p class="text-gray-500 text-sm mt-0.5">MediaPipe ile 33 eklem noktası analizi ve otomatik postür değerlendirmesi</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- For Students -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition-all">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-cyan-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-600"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900">Öğrenciler İçin</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <span class="font-semibold text-gray-900">Kişisel Antrenman Programı</span>
                <p class="text-gray-500 text-sm mt-0.5">Eğitmeninizin size özel hazırladığı programlara anında erişin</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <span class="font-semibold text-gray-900">Beslenme Planı Takibi</span>
                <p class="text-gray-500 text-sm mt-0.5">Günlük kalori ve makro hedeflerinizi görün, öğünlerinizi planlayın</p>
              </div>
