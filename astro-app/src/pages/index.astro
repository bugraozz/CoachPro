---
import { getUserFromRequest, isBackofficeUser } from '../lib/auth';
import {
  calculateDiscountedAmount,
  getCoachSubscriptionPlanDiscounts,
  getCoachSubscriptionPlans,
  getGlobalCoachSubscriptionDiscount,
  resolveCoachSubscriptionDiscountAmount,
} from '../lib/pricing';
import { getHomeTextOverrides } from '../lib/site-content';
import BorderGlow from '../components/BorderGlow';
import ShapeGrid from '../components/ShapeGrid';
import PublicLayout from '../layouts/PublicLayout.astro';

const DEFAULT_MONTHLY_PRICE_TRY = 299;
const DEFAULT_YEARLY_PRICE_TRY = 2990;

const user = await getUserFromRequest(Astro.request);
const [globalCoachDiscount, coachPlanDiscounts, coachPlans, homeTextOverrides] = await Promise.all([
  getGlobalCoachSubscriptionDiscount(),
  getCoachSubscriptionPlanDiscounts(),
  getCoachSubscriptionPlans(),
  getHomeTextOverrides(),
]);

const coachMonthlyPlan =
  coachPlans.find((plan) => plan.id === 'monthly') ||
  coachPlans[0] ||
  {
    id: 'monthly',
    label: 'Aylik Plan',
    months: 1,
    price: DEFAULT_MONTHLY_PRICE_TRY,
    description: 'Aylik yenilenen esnek egitmen plani',
    recommended: false,
  };

const coachYearlyPlan =
  coachPlans.find((plan) => plan.id === 'yearly') ||
  coachPlans.find((plan) => plan.id !== coachMonthlyPlan.id) ||
  {
    id: 'yearly',
    label: 'Yillik Plan',
    months: 12,
    price: DEFAULT_YEARLY_PRICE_TRY,
    description: '12 ay erisim saglayan yillik egitmen plani',
    recommended: true,
  };

const monthlyDiscountAmount = resolveCoachSubscriptionDiscountAmount({
  planId: coachMonthlyPlan.id,
  planDiscounts: coachPlanDiscounts,
  globalDiscount: globalCoachDiscount,
});

const yearlyDiscountAmount = resolveCoachSubscriptionDiscountAmount({
  planId: coachYearlyPlan.id,
  planDiscounts: coachPlanDiscounts,
  globalDiscount: globalCoachDiscount,
});

const coachMonthlyPricing = calculateDiscountedAmount(coachMonthlyPlan.price, monthlyDiscountAmount);
const coachYearlyPricing = calculateDiscountedAmount(coachYearlyPlan.price, yearlyDiscountAmount);

const yearlyMonthlyEquivalent = Math.max(1, Math.round(coachYearlyPricing.finalAmount / 12));
const yearlySavingsComparedToMonthly = Math.max(
  0,
  coachMonthlyPricing.finalAmount * 12 - coachYearlyPricing.finalAmount,
);

const homeText = (key: string, fallback: string): string => {
  const value = homeTextOverrides[key];
  if (typeof value !== 'string') {
    return fallback;
  }

  const normalized = value.trim();
  return normalized || fallback;
};

// Giriş yapmışsa dashboard'a yönlendir
if (user) {
  if (isBackofficeUser(user)) {
    return Astro.redirect('/admin');
  }
  return Astro.redirect('/dashboard');
}
---

