---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach } from '../../lib/auth';
import prisma from '../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

const userIsCoach = isCoach(user);

let programs: any[] = [];
let students: any[] = [];

if (userIsCoach) {
  students = await prisma.user.findMany({
    where: { coachId: user.id, role: 'student' },
    select: { id: true, name: true },
    orderBy: { name: 'asc' },
  });
  
  programs = await prisma.program.findMany({
    where: { user: { coachId: user.id } },
    include: {
      user: { select: { id: true, name: true } },
      days: {
        include: { exercises: true },
        orderBy: { order: 'asc' }
      }
    },
    orderBy: { createdAt: 'desc' },
  });
} else {
  programs = await prisma.program.findMany({
    where: { userId: user.id },
    include: {
      user: { select: { id: true, name: true } },
      days: {
        include: { exercises: true },
        orderBy: { order: 'asc' }
      }
    },
    orderBy: { createdAt: 'desc' },
  });
}
---

<MainLayout title="Antrenman Programları" activePage="programs">
  <header class="section-header">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="animate-in">
        <h1>Antrenman Programları</h1>
        <p>{userIsCoach ? `${programs.length} program oluşturulmuş` : `Toplam ${programs.length} programın bulunuyor`}</p>
      </div>
    </div>
  </header>

  <div class="page-content">
    <div>
      {programs.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {programs.map((program: any, index: number) => (
            <div class={`card-accent flex flex-col animate-in-${Math.min(index + 1, 6)}`} style={`--accent-stripe: ${program.status === 'active' ? 'linear-gradient(90deg, #10b981, #34d399)' : 'linear-gradient(90deg, #94a3b8, #cbd5e1)'}`}>
              
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-3">
                  <div class={`w-11 h-11 rounded-xl flex items-center justify-center ${program.status === 'active' ? 'bg-accent-green/12' : 'bg-bg-tertiary'}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={program.status === 'active' ? 'text-accent-green' : 'text-text-muted'}><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>
                  </div>
                  <div>
                    <h2 class="text-base font-bold text-text-primary">
                      <a href={`/programs/${program.id}`} class="hover:text-accent-primary transition-colors">{program.name}</a>
                    </h2>
                    {userIsCoach ? (
                      <a href={`/students/${program.user.id}`} class="text-sm text-accent-primary hover:underline font-medium">{program.user.name}</a>
                    ) : (
                      <span class={`text-xs font-medium ${program.status === 'active' ? 'text-accent-green' : 'text-text-muted'}`}>{program.status === 'active' ? 'Aktif Program' : 'Pasif Program'}</span>
                    )}
                  </div>
                </div>
              </div>
              
              <div class="flex-1">
                <div class="flex items-center gap-5 text-sm text-text-muted mb-4 pb-4 border-b border-border-default/50">
                    <div>
                      <span class="block text-lg font-bold text-text-primary">{program.days.length}</span>
                      <span class="text-xs font-medium">Gün</span>
                    </div>
                    <div>
                      <span class="block text-lg font-bold text-text-primary">{program.days.reduce((acc: number, day: any) => acc + day.exercises.length, 0)}</span>
                      <span class="text-xs font-medium">Egzersiz</span>
                    </div>
                     <div>
                      <span class="block text-sm font-semibold text-text-primary">{program.category || 'Fitness'}</span>
                      <span class="text-xs font-medium">Kategori</span>
                    </div>
                </div>
              </div>
              
              <div class="flex items-center justify-end gap-2 mt-auto pt-2">
                <a href={`/programs/${program.id}`} class="px-3.5 py-1.5 rounded-lg bg-accent-blue/8 text-accent-blue text-xs font-semibold hover:bg-accent-blue/15 transition-colors">Görüntüle</a>
                {userIsCoach && (
                  <>
                    <a href={`/students/${program.user.id}/program/${program.id}/edit`} class="px-3.5 py-1.5 rounded-lg bg-accent-primary/8 text-accent-primary text-xs font-semibold hover:bg-accent-primary/15 transition-colors">Düzenle</a>
                    <button onclick={`if(confirm('Programı silmek istiyor musun?')) { fetch('/api/programs/${program.id}', {method:'DELETE'}).then(r => r.ok ? location.reload() : alert('Hata')) }`} class="px-3.5 py-1.5 rounded-lg bg-accent-red/8 text-accent-red text-xs font-semibold hover:bg-accent-red/15 transition-colors">Sil</button>
                  </>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state animate-in">
          <div class="empty-state-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>
          </div>
          <p class="empty-state-title">Henüz program yok</p>
          <p class="empty-state-description">
             {userIsCoach ? 'Öğrenci detay sayfasından program oluşturabilirsiniz.' : 'Eğitmeniniz size bir antrenman programı atadığında burada görüntülenecek.'}
          </p>
          {userIsCoach && students.length > 0 && (
            <a href={`/students/${students[0].id}/program/new`} class="btn-primary">İlk Programı Oluştur</a>
          )}
        </div>
      )}
    </div>
  </div>
</MainLayout>
