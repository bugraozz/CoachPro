---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach, isStudent } from '../../lib/auth';
import prisma from '../../lib/prisma';

const user = await getUserFromRequest(Astro.request);
if (!user) return Astro.redirect('/auth/login');

// Eğer öğrenciyse, direkt olarak hocasıyla olan son mesaja gitsin veya listede hocasını görsün
type BasicContact = { id: string; name: string; photoUrl: string | null; role: string };

type ConversationPreview = {
  senderId: string;
  receiverId: string;
  content: string | null;
  messageType: string;
  fileName: string | null;
  createdAt: Date;
};

type ContactCard = BasicContact & {
  lastMessage: string;
  lastMessageAt: Date | null;
  unreadCount: number;
};

let contacts: BasicContact[] = [];

if (isCoach(user)) {
  contacts = await prisma.user.findMany({
    where: { coachId: user.id },
    select: { id: true, name: true, photoUrl: true, role: true }
  });
} else if (isStudent(user) && user.coachId) {
  contacts = await prisma.user.findMany({
    where: { id: user.coachId },
    select: { id: true, name: true, photoUrl: true, role: true }
  });
}

function getMessagePreview(message: ConversationPreview | null, currentUserId: string): string {
  if (!message) {
    return 'Henüz mesaj yok. Sohbeti başlatın.';
  }

  const prefix = message.senderId === currentUserId ? 'Siz: ' : '';

  if (message.messageType === 'image') {
    return `${prefix}Bir fotoğraf paylaşıldı`;
  }

  if (message.messageType === 'file') {
    return `${prefix}${message.fileName || 'Bir dosya'} gönderildi`;
  }

  const text = (message.content || '').trim();
  return text ? `${prefix}${text}` : `${prefix}Mesaj gönderildi`;
}

function formatRelativeTime(value: Date | null): string {
  if (!value) {
    return 'Yeni';
  }

  const diffMs = Date.now() - value.getTime();
  const diffMin = Math.floor(diffMs / 60000);

  if (diffMin < 1) return 'Şimdi';
  if (diffMin < 60) return `${diffMin} dk`;

  const diffHour = Math.floor(diffMin / 60);
  if (diffHour < 24) return `${diffHour} sa`;

  const diffDay = Math.floor(diffHour / 24);
  if (diffDay < 7) return `${diffDay} gün`;

  return value.toLocaleDateString('tr-TR', { day: '2-digit', month: 'short' });
}

let contactCards: ContactCard[] = [];
let totalUnread = 0;

if (contacts.length > 0) {
  const contactIds = contacts.map((contact) => contact.id);

  const messages = await prisma.message.findMany({
    where: {
      OR: [
        { senderId: user.id, receiverId: { in: contactIds } },
        { senderId: { in: contactIds }, receiverId: user.id }
      ]
    },
    select: {
      senderId: true,
      receiverId: true,
      content: true,
      messageType: true,
      fileName: true,
      createdAt: true
    },
    orderBy: { createdAt: 'desc' }
  });

  const latestByContact = new Map<string, ConversationPreview>();
  for (const message of messages) {
    const contactId = message.senderId === user.id ? message.receiverId : message.senderId;
    if (!latestByContact.has(contactId)) {
      latestByContact.set(contactId, message);
    }
  }

  const unreadGroups = await prisma.message.groupBy({
    by: ['senderId'],
    where: {
      senderId: { in: contactIds },
      receiverId: user.id,
      read: false
    },
    _count: { _all: true }
  });

  const unreadByContact = new Map<string, number>();
  for (const group of unreadGroups) {
    unreadByContact.set(group.senderId, group._count._all);
    totalUnread += group._count._all;
  }

  contactCards = contacts
    .map((contact) => {
      const latest = latestByContact.get(contact.id) || null;
      const unreadCount = unreadByContact.get(contact.id) || 0;

      return {
        ...contact,
        lastMessage: getMessagePreview(latest, user.id),
        lastMessageAt: latest?.createdAt ?? null,
        unreadCount
      };
    })
    .sort((left, right) => {
      if (left.lastMessageAt && right.lastMessageAt) {
        return right.lastMessageAt.getTime() - left.lastMessageAt.getTime();
      }
      if (left.lastMessageAt) return -1;
      if (right.lastMessageAt) return 1;
      return left.name.localeCompare(right.name, 'tr');
    });
}
---

<MainLayout title="Mesajlar" activePage="messages">
  <header class="section-header">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="animate-in">
        <h1>Mesajlar</h1>
        <p>{isCoach(user) ? 'Öğrencilerinizle sohbet akışını buradan yönetebilirsiniz.' : 'Eğitmeninizle olan konuşmalarınız tek listede.'}</p>
      </div>

      <div class="flex items-center gap-3 text-xs sm:text-sm animate-in-2">
        <div class="px-3.5 py-2 rounded-xl border border-border-default bg-bg-card text-text-secondary shadow-sm">
          Sohbet: <span class="font-bold text-text-primary">{contactCards.length}</span>
        </div>
        <div class="px-3.5 py-2 rounded-xl border border-border-default bg-bg-card text-text-secondary shadow-sm">
          Okunmamış: <span class="font-bold text-accent-primary">{totalUnread}</span>
        </div>
      </div>
    </div>
  </header>

  <div class="page-content max-w-5xl mx-auto">
    {contactCards.length > 0 ? (
      <div class="grid grid-cols-1 gap-3">
        {contactCards.map((contact) => (
          <a
            href={`/messages/${contact.id}`}
            class="group card p-4 sm:p-5 hover:border-accent-primary/30 hover:shadow-lg hover:shadow-accent-primary/5 transition-all duration-200"
          >
            <div class="flex items-start gap-4">
              <div class="relative w-13 h-13 rounded-full overflow-hidden bg-accent-primary/10 flex items-center justify-center text-accent-primary font-bold text-lg shrink-0 ring-1 ring-border-default">
                {contact.photoUrl ? (
                  <img src={contact.photoUrl} alt={contact.name} class="w-full h-full object-cover" />
                ) : (
                  contact.name.charAt(0).toUpperCase()
                )}

                {contact.unreadCount > 0 && (
                  <span class="absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full bg-accent-primary text-white text-[10px] font-bold flex items-center justify-center shadow-md">
                    {contact.unreadCount > 99 ? '99+' : contact.unreadCount}
                  </span>
                )}
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <h3 class="text-base font-semibold text-text-primary truncate group-hover:text-accent-primary transition-colors">
                      {contact.name}
                    </h3>
                    <p class="text-xs text-text-muted mt-0.5">{contact.role === 'coach' ? 'Eğitmen' : 'Öğrenci'}</p>
                  </div>
                  <div class="shrink-0 mt-0.5 text-right">
                    <span class="block text-xs text-text-muted">{formatRelativeTime(contact.lastMessageAt)}</span>
                    {contact.unreadCount > 0 && (
                      <span class="mt-1 inline-flex items-center rounded-md bg-accent-primary/10 px-2 py-0.5 text-[11px] font-semibold text-accent-primary">
                        {contact.unreadCount} okunmamış
                      </span>
                    )}
                  </div>
                </div>

                <p class="mt-3 text-sm text-text-secondary truncate">{contact.lastMessage}</p>

                <div class="mt-3 flex items-center justify-between">
                  <div class="text-xs text-text-muted">Konuşmayı aç</div>
                  <div class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-primary opacity-80 group-hover:opacity-100 transition-opacity">
                    <span>Sohbete git</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </div>
                </div>
              </div>

            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state animate-in">
        <div class="empty-state-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
        </div>
        <p class="empty-state-title">Henüz sohbet edebileceğiniz bir kişi bulunmuyor</p>
        <p class="empty-state-description">Yeni bir öğrenci/eğitmen bağlantısı sonrası bu alan otomatik dolacaktır.</p>
      </div>
    )}
  </div>
</MainLayout>
