---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isBackofficeUser, isCoach, isStudent } from '../../lib/auth';
import prisma from '../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (isBackofficeUser(user)) {
  return Astro.redirect('/admin');
}

const userIsCoach = isCoach(user); 
let students: any[] = [];
let recentPaidNotifications: any[] = [];

if (userIsCoach) {
  students = await prisma.user.findMany({
    where: { coachId: user.id, role: 'student' },
    include: {
      weightHistory: { orderBy: { date: 'desc' }, take: 1 },
      programs: { where: { status: 'active' } },
      dietPlans: { where: { active: true } },
      selectedPackage: true,
    },
    orderBy: { createdAt: 'desc' },
  });

  recentPaidNotifications = await prisma.paymentTransaction.findMany({
    where: {
      coachId: user.id,
      type: 'student_package',
      status: 'paid',
    },
    include: {
      student: {
        select: {
          id: true,
          name: true,
        },
      },
      coachPackage: {
        select: {
          name: true,
        },
      },
    },
    orderBy: { paidAt: 'desc' },
    take: 5,
  });
}

let coach: any = null;
let activeProgram: any = null;
let activeDiet: any = null;

if (isStudent(user)) {
  const studentData = await prisma.user.findUnique({
    where: { id: user.id },
    include: {
      coach: true,
      programs: { where: { status: 'active' }, include: { days: { include: { exercises: true } } }, take: 1 },
      dietPlans: { where: { active: true }, include: { meals: { include: { foods: true } } }, take: 1 },
    },
  });
  coach = studentData?.coach;
  activeProgram = studentData?.programs?.[0];
  activeDiet = studentData?.dietPlans?.[0];
}

const stats = {
  totalStudents: students.length,
  activePrograms: students.filter((s: any) => s.programs.length > 0).length,
  activeDiets: students.filter((s: any) => s.dietPlans.length > 0).length,
};

const recentStudents = students.slice(0, 5);
---

<MainLayout title="Dashboard" activePage="dashboard">
  <!-- Header -->
  <header class="px-6 lg:px-8 py-5 border-b border-border-default bg-bg-secondary/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">
          {userIsCoach ? `Hoş geldin, ${user.name}` : `Merhaba, ${user.name}`}
        </h1>
        <p class="text-sm text-text-secondary mt-1">
          {userIsCoach ? 'Öğrencilerini yönet ve gelişimlerini takip et.' : coach ? `Eğitmenin: ${coach.name}` : 'Dashboard'}
        </p>
      </div>
      <div class="flex items-center gap-3">
        {userIsCoach && (
          <a href="/students" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Öğrenci Ekle
          </a>
        )}
      </div>
    </div>
  </header>

  <div class="p-6 lg:p-8">
    {userIsCoach ? (
      <!-- COACH DASHBOARD -->
      <div>
        {recentPaidNotifications.length > 0 && (
          <div class="card mb-6 border border-accent-green/25 bg-accent-green/5">
            <div class="flex items-center justify-between gap-3 mb-4">
              <div>
                <h3 class="text-base font-semibold text-text-primary">Yeni Ogrenci Bildirimleri</h3>
                <p class="text-xs text-text-muted mt-1">Son basarili ogrenci odemeleri</p>
              </div>
              <a href="/messages" class="text-xs font-medium text-accent-primary hover:text-accent-primary-hover transition-colors">Mesajlari Ac</a>
            </div>

            <div class="space-y-3">
              {recentPaidNotifications.map((payment: any) => (
                <div class="flex items-center justify-between gap-3 p-3 rounded-xl bg-bg-card border border-border-default">
                  <div>
                    <div class="text-sm font-medium text-text-primary">
                      {payment.student?.name || 'Ogrenci'} odemeyi tamamladi
                    </div>
                    <div class="text-xs text-text-muted mt-0.5">
                      Paket: {payment.coachPackage?.name || 'Standart Paket'}
                    </div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-sm font-semibold text-accent-green">₺{payment.amount}</div>
                    <div class="text-xs text-text-muted">
                      {new Date(payment.paidAt || payment.createdAt).toLocaleDateString('tr-TR')}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
          <div class="card group relative overflow-hidden">
            <div class="absolute inset-0 bg-linear-to-br from-accent-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Toplam Öğrenci</span>
                <div class="w-10 h-10 rounded-xl bg-accent-primary/50 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-primary"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
              </div>
              <div class="text-3xl font-bold text-text-primary">{stats.totalStudents}</div>
              <div class="text-xs text-text-muted mt-1">kayıtlı öğrenci</div>
            </div>
          </div>

          <div class="card group relative overflow-hidden">
            <div class="absolute inset-0 bg-linear-to-br from-accent-green/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Aktif Program</span>
                <div class="w-10 h-10 rounded-xl bg-accent-green/15 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-green"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>
                </div>
              </div>
              <div class="text-3xl font-bold text-text-primary">{stats.activePrograms}</div>
              <div class="text-xs text-text-muted mt-1">aktif antrenman</div>
            </div>
          </div>

          <div class="card group relative overflow-hidden">
            <div class="absolute inset-0 bg-linear-to-br from-accent-orange/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Aktif Diyet</span>
                <div class="w-10 h-10 rounded-xl bg-accent-orange/15 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-orange"><path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/><path d="M7 21h10"/></svg>
                </div>
              </div>
              <div class="text-3xl font-bold text-text-primary">{stats.activeDiets}</div>
              <div class="text-xs text-text-muted mt-1">aktif diyet planı</div>
            </div>
          </div>

          <div class="card group relative overflow-hidden">
            <div class="absolute inset-0 bg-linear-to-br from-accent-cyan/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Referans Kodu</span>
                <div class="w-10 h-10 rounded-xl bg-accent-cyan/50 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                </div>
              </div>
              <div class="text-xl font-bold text-accent-cyan font-mono tracking-widest">{user.referralCode || 'â€”'}</div>
              <button onclick={`navigator.clipboard.writeText('${user.referralCode || ''}'); this.textContent='Kopyalandı!'; setTimeout(()=>this.textContent='Kopyala',2000)`} class="text-xs text-accent-cyan hover:text-accent-cyan/80 mt-1 cursor-pointer transition-colors">Kopyala</button>
            </div>
          </div>
        </div>

        <!-- Students Table -->
        <div class="card">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="text-lg font-semibold text-text-primary">Öğrencilerim</h3>
              <p class="text-sm text-text-muted mt-0.5">Son eklenen öğrenciler</p>
            </div>
            <a href="/students" class="text-sm font-medium text-accent-primary hover:text-accent-primary-hover transition-colors">Tümünü Gör â†’</a>
          </div>
          
          {recentStudents.length > 0 ? (
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="border-b border-border-default">
                    <th class="text-left py-3 px-4 text-xs font-semibold uppercase tracking-wider text-text-muted">Öğrenci</th>
                    <th class="text-left py-3 px-4 text-xs font-semibold uppercase tracking-wider text-text-muted">Kilo</th>
                    <th class="text-left py-3 px-4 text-xs font-semibold uppercase tracking-wider text-text-muted">Program</th>
                    <th class="text-left py-3 px-4 text-xs font-semibold uppercase tracking-wider text-text-muted">Diyet</th>
                    <th class="text-left py-3 px-4 text-xs font-semibold uppercase tracking-wider text-text-muted">Ödeme</th>
                    <th class="text-left py-3 px-4 text-xs font-semibold uppercase tracking-wider text-text-muted">Durum</th>
                    <th class="text-right py-3 px-4 text-xs font-semibold uppercase tracking-wider text-text-muted">İşlem</th>
                  </tr>
                </thead>
                <tbody>
                  {recentStudents.map((student: any) => (
                    <tr class="border-b border-border-default/50 hover:bg-bg-tertiary/30 transition-colors">
                      <td class="py-4 px-4">
                        <div class="flex items-center gap-3">
                          <div class="w-9 h-9 rounded-full bg-linear-to-br from-accent-purple to-accent-primary flex items-center justify-center text-xs font-bold text-white shrink-0">
                            {student.name.charAt(0).toUpperCase()}
                          </div>
                          <div>
                            <div class="text-sm font-medium text-text-primary">{student.name}</div>
                            <div class="text-xs text-text-muted">{student.email}</div>
                            <div class="text-xs text-text-muted mt-0.5">
                              Paket: {student.selectedPackage?.name || 'Seçilmedi'}
                            </div>
                          </div>
                        </div>
                      </td>
                      <td class="py-4 px-4 text-sm text-text-secondary">
                        {student.currentWeight ? `${student.currentWeight} kg` : 'â€”'}
                      </td>
                      <td class="py-4 px-4">
                        {student.programs.length > 0 
                          ? <span class="badge badge-success">Aktif</span>
                          : <span class="badge" style="background:rgba(239,68,68,0.15);color:var(--color-accent-red);border:1px solid rgba(239,68,68,0.2)">Yok</span>
                        }
                      </td>
                      <td class="py-4 px-4">
                        {student.dietPlans.length > 0 
                          ? <span class="badge badge-success">Aktif</span>
                          : <span class="badge" style="background:rgba(239,68,68,0.15);color:var(--color-accent-red);border:1px solid rgba(239,68,68,0.2)">Yok</span>
                        }
                      </td>
                      <td class="py-4 px-4">
                        {student.studentPaymentStatus === 'paid'
                          ? <span class="badge badge-success">Ücret Ödendi</span>
                          : <span class="badge" style="background:rgba(239,68,68,0.15);color:var(--color-accent-red);border:1px solid rgba(239,68,68,0.2)">Ödeme Bekleniyor</span>
                        }
                      </td>
                      <td class="py-4 px-4">
                        <span class={`inline-flex items-center gap-1.5 text-xs font-medium ${student.active ? 'text-accent-green' : 'text-accent-red'}`}>
                          <span class={`w-2 h-2 rounded-full ${student.active ? 'bg-accent-green' : 'bg-accent-red'}`}></span>
                          {student.active ? 'Aktif' : 'Pasif'}
                        </span>
                      </td>
                      <td class="py-4 px-4 text-right">
                        <a href={`/students/${student.id}`} class="text-sm font-medium text-accent-primary hover:text-accent-primary-hover transition-colors">Detay</a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="text-center py-12">
              <div class="w-16 h-16 rounded-2xl bg-bg-tertiary flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <p class="text-text-secondary font-medium mb-1">Henüz öğrenciniz yok</p>
              <p class="text-sm text-text-muted mb-4">Referans kodunuzu paylaşarak öğrenci ekleyin</p>
              <a href="/students" class="btn-primary">Öğrenci Yönetimi</a>
            </div>
          )}
        </div>

      </div>
    ) : (
      <!-- STUDENT DASHBOARD -->
      <div>
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <div class="card">
            <div class="text-2xl font-bold text-accent-primary">{user.currentWeight || 'â€”'}</div>
            <div class="text-sm text-text-muted">Mevcut Kilo (kg)</div>
          </div>
          <div class="card">
            <div class="text-2xl font-bold text-accent-green">{user.targetWeight || 'â€”'}</div>
            <div class="text-sm text-text-muted">Hedef Kilo (kg)</div>
          </div>
          <div class="card">
            <div class="text-2xl font-bold text-accent-orange">{user.height || 'â€”'}</div>
            <div class="text-sm text-text-muted">Boy (cm)</div>
          </div>
          <div class="card">
            <div class="text-2xl font-bold text-accent-cyan">
              {user.currentWeight && user.height
                ? (user.currentWeight / ((user.height / 100) ** 2)).toFixed(1)
                : 'â€”'}
            </div>
            <div class="text-sm text-text-muted">BMI</div>
          </div>
        </div>

        <!-- Active Program & Diet -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-text-primary">Aktif Program</h3>
              <a href={activeProgram ? `/programs/${activeProgram.id}` : "/programs"} class="text-sm text-accent-primary hover:text-accent-primary-hover transition-colors">Detay â†’</a>
            </div>
            {activeProgram ? (
              <div>
                <div class="text-base font-medium text-text-primary mb-2">{activeProgram.name}</div>
                <div class="flex items-center gap-2">
                  <span class="badge badge-success">{activeProgram.days?.length || 0} gün / hafta</span>
                  <span class="badge" style="background:rgba(99,102,241,0.15);color:var(--color-accent-primary);border:1px solid rgba(99,102,241,0.2)">Aktif</span>
                </div>
                {activeProgram.days && activeProgram.days.length > 0 && (
                  <div class="mt-4 space-y-2">
                    {activeProgram.days.slice(0, 3).map((day: any) => (
                      <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-bg-tertiary/50">
                        <span class="text-sm font-medium text-text-primary">{day.dayName}</span>
                        <span class="text-xs text-text-muted">{day.exercises?.length || 0} egzersiz</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ) : (
              <div class="text-center py-8">
                <div class="w-12 h-12 rounded-xl bg-bg-tertiary flex items-center justify-center mx-auto mb-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="m6.5 6.5 11 11"/></svg>
                </div>
                <p class="text-sm text-text-muted">Henüz program atanmamış</p>
              </div>
            )}
          </div>

          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-text-primary">Aktif Diyet</h3>
              <a href="/diet" class="text-sm text-accent-primary hover:text-accent-primary-hover transition-colors">Detay â†’</a>
            </div>
            {activeDiet ? (
              <div>
                <div class="text-base font-medium text-text-primary mb-2">{activeDiet.name}</div>
                <div class="flex flex-wrap items-center gap-2 mb-4">
                  <span class="badge badge-success">{activeDiet.dailyCalorieTarget} kcal</span>
                  <span class="badge" style="background:rgba(59,130,246,0.15);color:var(--color-accent-blue);border:1px solid rgba(59,130,246,0.2)">{activeDiet.proteinTarget}g protein</span>
                  <span class="badge" style="background:rgba(249,115,22,0.15);color:var(--color-accent-orange);border:1px solid rgba(249,115,22,0.2)">{activeDiet.carbsTarget}g karb</span>
                  <span class="badge" style="background:rgba(234,179,8,0.15);color:var(--color-accent-yellow);border:1px solid rgba(234,179,8,0.2)">{activeDiet.fatTarget}g yağ</span>
                </div>
                {activeDiet.meals && activeDiet.meals.length > 0 && (
                  <div class="space-y-2">
                    {activeDiet.meals.slice(0, 3).map((meal: any) => (
                      <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-bg-tertiary/50">
                        <span class="text-sm font-medium text-text-primary">{meal.name}</span>
                        <span class="text-xs text-text-muted">{meal.foods?.length || 0} besin</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ) : (
              <div class="text-center py-8">
                <div class="w-12 h-12 rounded-xl bg-bg-tertiary flex items-center justify-center mx-auto mb-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/></svg>
                </div>
                <p class="text-sm text-text-muted">Henüz diyet atanmamış</p>
              </div>
            )}
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <a href="/analysis" class="card-interactive flex flex-col items-center gap-3 py-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-accent-purple/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-purple"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            </div>
            <span class="text-sm font-medium text-text-primary">Vücut Analizi</span>
          </a>
          <a href="/programs" class="card-interactive flex flex-col items-center gap-3 py-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-accent-green/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-green"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/></svg>
            </div>
            <span class="text-sm font-medium text-text-primary">Programlar</span>
          </a>
          <a href="/diet" class="card-interactive flex flex-col items-center gap-3 py-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-accent-orange/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-orange"><path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/><path d="M7 21h10"/></svg>
            </div>
            <span class="text-sm font-medium text-text-primary">Diyet</span>
          </a>
          <a href="/progress" class="card-interactive flex flex-col items-center gap-3 py-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-accent-cyan/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            </div>
            <span class="text-sm font-medium text-text-primary">Gelişim</span>
          </a>
        </div>
      </div>
    )}
  </div>
</MainLayout>
