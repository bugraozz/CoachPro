---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isBackofficeUser, isCoach, isStudent } from '../../lib/auth';
import prisma from '../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (isBackofficeUser(user)) {
  return Astro.redirect('/admin');
}

const userIsCoach = isCoach(user); 
let students: any[] = [];
let recentPaidNotifications: any[] = [];

if (userIsCoach) {
  students = await prisma.user.findMany({
    where: { coachId: user.id, role: 'student' },
    include: {
      weightHistory: { orderBy: { date: 'desc' }, take: 1 },
      programs: { where: { status: 'active' } },
      dietPlans: { where: { active: true } },
      selectedPackage: true,
    },
    orderBy: { createdAt: 'desc' },
  });

  recentPaidNotifications = await prisma.paymentTransaction.findMany({
    where: {
      coachId: user.id,
      type: 'student_package',
      status: 'paid',
    },
    include: {
      student: {
        select: {
          id: true,
          name: true,
        },
      },
      coachPackage: {
        select: {
          name: true,
        },
      },
    },
    orderBy: { paidAt: 'desc' },
    take: 5,
  });
}

let coach: any = null;
let activeProgram: any = null;
let activeDiet: any = null;

if (isStudent(user)) {
  const studentData = await prisma.user.findUnique({
    where: { id: user.id },
    include: {
      coach: true,
      programs: { where: { status: 'active' }, include: { days: { include: { exercises: true } } }, take: 1 },
      dietPlans: { where: { active: true }, include: { meals: { include: { foods: true } } }, take: 1 },
    },
  });
  coach = studentData?.coach;
  activeProgram = studentData?.programs?.[0];
  activeDiet = studentData?.dietPlans?.[0];
}

const stats = {
  totalStudents: students.length,
  activePrograms: students.filter((s: any) => s.programs.length > 0).length,
  activeDiets: students.filter((s: any) => s.dietPlans.length > 0).length,
};

const recentStudents = students.slice(0, 5);
---

<MainLayout title="Dashboard" activePage="dashboard">
  <!-- Header -->
  <header class="section-header">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="animate-in">
        <h1>{userIsCoach ? `Hoş geldin, ${user.name}` : `Merhaba, ${user.name}`}</h1>
        <p>{userIsCoach ? 'Öğrencilerini yönet ve gelişimlerini takip et.' : coach ? `Eğitmenin: ${coach.name}` : 'Dashboard'}</p>
      </div>
      <div class="flex items-center gap-3 animate-in-2">
        {userIsCoach && (
          <a href="/students" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Öğrenci Ekle
          </a>
        )}
      </div>
    </div>
  </header>

  <div class="page-content">
    {userIsCoach ? (
      <!-- COACH DASHBOARD -->
      <div>
        {recentPaidNotifications.length > 0 && (
          <div class="notification-card mb-6 animate-in-1">
            <div class="flex items-center justify-between gap-3 mb-4">
              <div>
                <h3 class="text-base font-semibold text-text-primary">Yeni Ogrenci Bildirimleri</h3>
                <p class="text-xs text-text-muted mt-0.5">Son basarili ogrenci odemeleri</p>
              </div>
              <a href="/messages" class="text-xs font-medium text-accent-primary hover:text-accent-primary-hover transition-colors">Mesajlari Ac →</a>
            </div>

            <div class="space-y-2.5">
              {recentPaidNotifications.map((payment: any) => (
                <div class="flex items-center justify-between gap-3 p-3 rounded-xl bg-bg-card border border-border-default hover:border-border-hover transition-colors">
                  <div>
                    <div class="text-sm font-medium text-text-primary">
                      {payment.student?.name || 'Ogrenci'} odemeyi tamamladi
                    </div>
                    <div class="text-xs text-text-muted mt-0.5">
                      Paket: {payment.coachPackage?.name || 'Standart Paket'}
                    </div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-sm font-semibold text-accent-green">₺{payment.amount}</div>
                    <div class="text-xs text-text-muted">
                      {new Date(payment.paidAt || payment.createdAt).toLocaleDateString('tr-TR')}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
          <div class="stat-card animate-in-1" style="--stat-accent: linear-gradient(90deg, #CD0000, #ff4444)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Toplam Öğrenci</span>
              <div class="stat-icon bg-accent-primary/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-primary"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
            </div>
            <div class="stat-value">{stats.totalStudents}</div>
            <div class="stat-label">kayıtlı öğrenci</div>
          </div>

          <div class="stat-card animate-in-2" style="--stat-accent: linear-gradient(90deg, #10b981, #34d399)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Aktif Program</span>
              <div class="stat-icon bg-accent-green/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-green"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>
              </div>
            </div>
            <div class="stat-value">{stats.activePrograms}</div>
            <div class="stat-label">aktif antrenman</div>
          </div>

          <div class="stat-card animate-in-3" style="--stat-accent: linear-gradient(90deg, #f97316, #fb923c)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Aktif Diyet</span>
              <div class="stat-icon bg-accent-orange/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-orange"><path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/><path d="M7 21h10"/></svg>
              </div>
            </div>
            <div class="stat-value">{stats.activeDiets}</div>
            <div class="stat-label">aktif diyet planı</div>
          </div>

          <div class="stat-card animate-in-4" style="--stat-accent: linear-gradient(90deg, #06b6d4, #22d3ee)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Referans Kodu</span>
              <div class="stat-icon bg-accent-cyan/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              </div>
            </div>
            <div class="text-xl font-bold text-accent-cyan font-mono tracking-widest">{user.referralCode || '—'}</div>
            <button onclick={`navigator.clipboard.writeText('${user.referralCode || ''}'); this.textContent='Kopyalandı!'; setTimeout(()=>this.textContent='Kopyala',2000)`} class="text-xs text-accent-cyan hover:text-accent-cyan/80 mt-1 cursor-pointer transition-colors font-medium">Kopyala</button>
          </div>
        </div>

        <!-- Students Table -->
        <div class="card animate-in-5">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="text-lg font-bold text-text-primary">Öğrencilerim</h3>
              <p class="text-sm text-text-muted mt-0.5">Son eklenen öğrenciler</p>
            </div>
            <a href="/students" class="text-sm font-medium text-accent-primary hover:text-accent-primary-hover transition-colors flex items-center gap-1">
              Tümünü Gör
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
          
          {recentStudents.length > 0 ? (
            <div class="overflow-x-auto -mx-6 px-6">
              <table class="premium-table">
                <thead>
                  <tr>
                    <th>Öğrenci</th>
                    <th>Kilo</th>
                    <th>Program</th>
                    <th>Diyet</th>
                    <th>Ödeme</th>
                    <th>Durum</th>
                    <th class="text-right">İşlem</th>
                  </tr>
                </thead>
                <tbody>
                  {recentStudents.map((student: any) => (
                    <tr>
                      <td>
                        <div class="flex items-center gap-3">
                          <div class="w-9 h-9 rounded-full bg-gradient-to-br from-accent-purple to-accent-primary flex items-center justify-center text-xs font-bold text-white shrink-0">
                            {student.name.charAt(0).toUpperCase()}
                          </div>
                          <div>
                            <div class="text-sm font-semibold text-text-primary">{student.name}</div>
                            <div class="text-xs text-text-muted">{student.email}</div>
                            <div class="text-xs text-text-muted mt-0.5">
                              {student.selectedPackage?.name || 'Paket seçilmedi'}
                            </div>
                          </div>
                        </div>
                      </td>
                      <td class="text-sm text-text-secondary font-medium">
                        {student.currentWeight ? `${student.currentWeight} kg` : '—'}
                      </td>
                      <td>
                        {student.programs.length > 0 
                          ? <span class="badge badge-success">Aktif</span>
                          : <span class="badge badge-danger">Yok</span>
                        }
                      </td>
                      <td>
                        {student.dietPlans.length > 0 
                          ? <span class="badge badge-success">Aktif</span>
                          : <span class="badge badge-danger">Yok</span>
                        }
                      </td>
                      <td>
                        {student.studentPaymentStatus === 'paid'
                          ? <span class="badge badge-success">Ödendi</span>
                          : <span class="badge badge-warning">Bekliyor</span>
                        }
                      </td>
                      <td>
                        <span class={`inline-flex items-center gap-1.5 text-xs font-semibold ${student.active ? 'text-accent-green' : 'text-accent-red'}`}>
                          <span class={`w-2 h-2 rounded-full ${student.active ? 'bg-accent-green' : 'bg-accent-red'}`}></span>
                          {student.active ? 'Aktif' : 'Pasif'}
                        </span>
                      </td>
                      <td class="text-right">
                        <a href={`/students/${student.id}`} class="inline-flex items-center gap-1 text-sm font-medium text-accent-primary hover:text-accent-primary-hover transition-colors">
                          Detay
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                        </a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="empty-state">
              <div class="empty-state-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <p class="empty-state-title">Henüz öğrenciniz yok</p>
              <p class="empty-state-description">Referans kodunuzu paylaşarak öğrenci ekleyin</p>
              <a href="/students" class="btn-primary">Öğrenci Yönetimi</a>
            </div>
          )}
        </div>

      </div>
    ) : (
      <!-- STUDENT DASHBOARD -->
      <div>
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
          <div class="stat-card animate-in-1" style="--stat-accent: linear-gradient(90deg, #CD0000, #ff4444)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Mevcut Kilo</span>
              <div class="stat-icon bg-accent-primary/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-primary"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
            </div>
            <div class="stat-value text-accent-primary">{user.currentWeight || '—'}</div>
            <div class="stat-label">kilogram</div>
          </div>
          <div class="stat-card animate-in-2" style="--stat-accent: linear-gradient(90deg, #10b981, #34d399)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Hedef Kilo</span>
              <div class="stat-icon bg-accent-green/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-green"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
              </div>
            </div>
            <div class="stat-value text-accent-green">{user.targetWeight || '—'}</div>
            <div class="stat-label">kilogram</div>
          </div>
          <div class="stat-card animate-in-3" style="--stat-accent: linear-gradient(90deg, #f97316, #fb923c)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Boy</span>
              <div class="stat-icon bg-accent-orange/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-orange"><path d="M21 3H3"/><path d="M21 21H3"/><path d="M12 3v18"/></svg>
              </div>
            </div>
            <div class="stat-value text-accent-orange">{user.height || '—'}</div>
            <div class="stat-label">santimetre</div>
          </div>
          <div class="stat-card animate-in-4" style="--stat-accent: linear-gradient(90deg, #06b6d4, #22d3ee)">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">BMI</span>
              <div class="stat-icon bg-accent-cyan/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
              </div>
            </div>
            <div class="stat-value text-accent-cyan">
              {user.currentWeight && user.height
                ? (user.currentWeight / ((user.height / 100) ** 2)).toFixed(1)
                : '—'}
            </div>
            <div class="stat-label">vücut kitle indeksi</div>
          </div>
        </div>

        <!-- Active Program & Diet -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
          <div class="card-accent animate-in-5" style="--accent-stripe: linear-gradient(90deg, #8b5cf6, #a78bfa)">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-text-primary">Aktif Program</h3>
              <a href={activeProgram ? `/programs/${activeProgram.id}` : "/programs"} class="text-sm text-accent-primary hover:text-accent-primary-hover transition-colors font-medium flex items-center gap-1">
                Detay
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </div>
            {activeProgram ? (
              <div>
                <div class="text-base font-semibold text-text-primary mb-3">{activeProgram.name}</div>
                <div class="flex items-center gap-2 mb-4">
                  <span class="badge badge-success">{activeProgram.days?.length || 0} gün / hafta</span>
                  <span class="badge badge-primary">Aktif</span>
                </div>
                {activeProgram.days && activeProgram.days.length > 0 && (
                  <div class="space-y-2">
                    {activeProgram.days.slice(0, 3).map((day: any) => (
                      <div class="flex items-center justify-between py-2.5 px-3.5 rounded-lg bg-bg-tertiary/50 border border-border-default/50">
                        <span class="text-sm font-medium text-text-primary">{day.dayName}</span>
                        <span class="text-xs text-text-muted font-medium">{day.exercises?.length || 0} egzersiz</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ) : (
              <div class="empty-state py-8">
                <div class="empty-state-icon" style="width:3rem;height:3rem;border-radius:0.75rem;margin-bottom:0.75rem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="m6.5 6.5 11 11"/></svg>
                </div>
                <p class="text-sm text-text-muted">Henüz program atanmamış</p>
              </div>
            )}
          </div>

          <div class="card-accent animate-in-6" style="--accent-stripe: linear-gradient(90deg, #f97316, #fb923c)">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-text-primary">Aktif Diyet</h3>
              <a href="/diet" class="text-sm text-accent-primary hover:text-accent-primary-hover transition-colors font-medium flex items-center gap-1">
                Detay
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </div>
            {activeDiet ? (
              <div>
                <div class="text-base font-semibold text-text-primary mb-3">{activeDiet.name}</div>
                <div class="flex flex-wrap items-center gap-2 mb-4">
                  <span class="badge badge-success">{activeDiet.dailyCalorieTarget} kcal</span>
                  <span class="badge badge-info">{activeDiet.proteinTarget}g protein</span>
                  <span class="badge badge-warning">{activeDiet.carbsTarget}g karb</span>
                  <span class="badge" style="background:rgba(234,179,8,0.12);color:#ca8a04;border:1px solid rgba(234,179,8,0.18);border-radius:9999px">{activeDiet.fatTarget}g yağ</span>
                </div>
                {activeDiet.meals && activeDiet.meals.length > 0 && (
                  <div class="space-y-2">
                    {activeDiet.meals.slice(0, 3).map((meal: any) => (
                      <div class="flex items-center justify-between py-2.5 px-3.5 rounded-lg bg-bg-tertiary/50 border border-border-default/50">
                        <span class="text-sm font-medium text-text-primary">{meal.name}</span>
                        <span class="text-xs text-text-muted font-medium">{meal.foods?.length || 0} besin</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ) : (
              <div class="empty-state py-8">
                <div class="empty-state-icon" style="width:3rem;height:3rem;border-radius:0.75rem;margin-bottom:0.75rem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/></svg>
                </div>
                <p class="text-sm text-text-muted">Henüz diyet atanmamış</p>
              </div>
            )}
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <a href="/analysis" class="quick-action animate-in-1">
            <div class="quick-action-icon bg-accent-purple/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-purple"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            </div>
            <span class="text-sm font-semibold text-text-primary">Vücut Analizi</span>
          </a>
          <a href="/programs" class="quick-action animate-in-2">
            <div class="quick-action-icon bg-accent-green/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-green"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/></svg>
            </div>
            <span class="text-sm font-semibold text-text-primary">Programlar</span>
          </a>
          <a href="/diet" class="quick-action animate-in-3">
            <div class="quick-action-icon bg-accent-orange/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-orange"><path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/><path d="M7 21h10"/></svg>
            </div>
            <span class="text-sm font-semibold text-text-primary">Diyet</span>
          </a>
          <a href="/progress" class="quick-action animate-in-4">
            <div class="quick-action-icon bg-accent-cyan/10">
