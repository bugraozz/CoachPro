---
import ShapeGrid from '../../components/ShapeGrid';
import {
  verifyPassword,
  createSession,
  createSessionCookie,
  createPaymentAccessCookie,
  createPaymentAccessToken,
  getUserFromRequest,
  isBackofficeUser,
  requiresPaymentStep,
  syncMembershipAccessState,
} from '../../lib/auth';
import prisma from '../../lib/prisma';
import PublicLayout from '../../layouts/PublicLayout.astro';

// Zaten giriş yapmışsa dashboard'a yönlendir
const user = await getUserFromRequest(Astro.request);
if (user) {
  return Astro.redirect('/dashboard');
}

let error = '';

if (Astro.request.method === 'POST') {
  const contentType = Astro.request.headers.get('content-type') || '';
  const isJsonRequest = contentType.toLowerCase().includes('application/json');
  const requestBody = isJsonRequest ? await Astro.request.json() : null;
  const formData = isJsonRequest ? null : await Astro.request.formData();

  const email = String(isJsonRequest ? requestBody?.email : formData?.get('email') || '').trim().toLowerCase();
  const password = String(isJsonRequest ? requestBody?.password : formData?.get('password') || '');

  if (!email || !password) {
    error = 'E-posta ve şifre gereklidir.';
  } else {
    const existingUser = await prisma.user.findUnique({ where: { email } });
    
    if (!existingUser) {
      if (isJsonRequest) {
        return new Response(JSON.stringify({ error: 'E-posta veya şifre hatalı.' }), {
          status: 401,
          headers: { 'Content-Type': 'application/json' },
        });
      }
      error = 'E-posta veya şifre hatalı.';
    } else {
      const user = await syncMembershipAccessState(existingUser);

      if (!user.active) {
        if (requiresPaymentStep(user)) {
          const paymentToken = createPaymentAccessToken(user.id);
          const headers = new Headers();
          headers.set('Location', `/auth/payment?userId=${encodeURIComponent(user.id)}`);
          headers.append('Set-Cookie', createPaymentAccessCookie(paymentToken));

          if (isJsonRequest) {
            const { password: _, ...safeUser } = user;
            return new Response(JSON.stringify({
              error: 'Hesabınız aktif değil. Lütfen ödeme işlemini tamamlayın.',
              requiresPayment: true,
              user: { id: user.id, email: user.email, name: user.name, role: user.role },
              paymentAccessToken: createPaymentAccessToken(user.id),
            }), {
              status: 403,
              headers: { 'Content-Type': 'application/json' },
            });
          }

          return new Response(null, {
            status: 302,
            headers,
          });
        }

        if (isJsonRequest) {
          return new Response(JSON.stringify({ error: 'Hesabınız aktif değil.' }), {
            status: 403,
            headers: { 'Content-Type': 'application/json' },
          });
        }

        error = 'Hesabınız aktif değil. Lütfen kayıt ödeme adımını tamamlayın.';
      } else {
        const isValid = await verifyPassword(password, user.password);
      
        if (!isValid) {
          if (isJsonRequest) {
            return new Response(JSON.stringify({ error: 'E-posta veya şifre hatalı.' }), {
              status: 401,
              headers: { 'Content-Type': 'application/json' },
            });
          }

          error = 'E-posta veya şifre hatalı.';
        } else {
          // Session oluştur
          const token = await createSession(user.id);

          if (isJsonRequest) {
            const { password: _, ...safeUser } = user;
            return new Response(JSON.stringify({
              success: true,
              token,
              user: safeUser,
            }), {
              status: 200,
              headers: { 'Content-Type': 'application/json' },
            });
          }

          const cookie = createSessionCookie(token);
          return new Response(null, {
            status: 302,
            headers: {
              'Location': isBackofficeUser(user) ? '/admin' : '/dashboard',
              'Set-Cookie': cookie,
            },
          });
        }
      }
    }
  }
}
---

<PublicLayout
  title="Giriş Yap - CoachPro"
  bodyClass="min-h-screen relative bg-white"
  bodyStyle="background-color: #ffffff;"
>
  <!-- Subtle ShapeGrid Background -->
  <div class="fixed inset-0 z-0 bg-white pointer-events-none opacity-10">
    <ShapeGrid
      client:load
      speed={0}
      squareSize={52}
      direction="diagonal"
      borderColor="rgba(148, 163, 184, 1.8)"
      hoverFillColor="transparent"
      shape="square"
      vignetteColor="transparent"
    />
  </div>

  <!-- Header -->
  <header class="fixed top-0 inset-x-0 z-50 bg-transparent">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-linear-to-br from-red-600 to-red-800 flex items-center justify-center text-white font-bold">CP</div>
        <span class="text-xl font-bold text-gray-900">CoachPro</span>
      </a>
      <div class="flex items-center gap-4">
        <a href="/auth/register" class="btn-primary">Ücretsiz Başla</a>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <section class="pt-32 pb-20 px-6 relative z-10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
      <div class="lg:pt-8">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-50 border border-red-200 text-red-600 text-sm font-medium mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          Hesabınıza Güvenle Giriş Yapın
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-5 leading-tight">
          Koçluk paneliniz
          <span class="relative inline-block whitespace-nowrap">
            <span class="relative z-10 text-red-500">tek tık uzağınızda</span>
            <svg class="absolute -bottom-2 left-0 w-full h-3 -rotate-1 text-red-500" viewBox="0 0 100 20" preserveAspectRatio="none" aria-hidden="true">
              <path d="M 2,12 Q 25,26 99,5" stroke="currentColor" stroke-width="7" stroke-linecap="round" fill="none" />
            </svg>
          </span>
        </h1>
        <p class="text-gray-600 text-lg max-w-xl mb-10">
          Öğrencilerinizi, programlarınızı ve analizlerinizi kaldığınız yerden yönetmek için hesabınıza giriş yapın.
        </p>

        <div class="grid grid-cols-3 gap-4 max-w-md">
          <div>
            <div class="text-2xl font-bold text-gray-900">10K+</div>
            <div class="text-xs text-gray-500 mt-1">Aktif Öğrenci</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-gray-900">500+</div>
            <div class="text-xs text-gray-500 mt-1">Eğitmen</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-gray-900">%98</div>
            <div class="text-xs text-gray-500 mt-1">Memnuniyet</div>
          </div>
        </div>
      </div>

      <div>
        <div class="text-center mb-8 lg:text-left">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">Tekrar Hoş Geldiniz</h2>
          <p class="text-gray-600">E-posta ve şifreniz ile giriş yapın</p>
        </div>

        <!-- Login Card -->
        <div class="bg-white/95 backdrop-blur-sm rounded-2xl border border-gray-200 shadow-sm p-8 sm:p-10">
        {error && (
          <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-600 text-sm flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            {error}
          </div>
        )}

        <form method="POST" class="space-y-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">E-posta</label>
            <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-400 transition-all" placeholder="ornek@email.com" required />
          </div>

          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="block text-sm font-medium text-gray-700" for="password">Şifre</label>
              <a href="/auth/forgot-password" class="text-sm font-medium text-red-600 hover:text-red-700">Şifremi Unuttum</a>
            </div>
            <div class="relative">
              <input type="password" id="password" name="password" class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-400 transition-all pr-11" placeholder="••••••••" required />
              <button type="button" id="togglePass" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <button type="submit" class="btn-primary w-full py-3 text-base">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
            Giriş Yap
          </button>
        </form>

        <div class="mt-6 pt-6 border-t border-gray-100 text-center">
          <p class="text-sm text-gray-500">
            Hesabınız yok mu? 
            <a href="/auth/register" class="text-red-600 hover:underline font-semibold">Ücretsiz Kayıt Ol</a>
          </p>
        </div>
      </div>

      <!-- Trust -->
      <div class="mt-8 text-center lg:text-left">
        <div class="flex items-center justify-center lg:justify-start gap-6 text-xs text-gray-400">
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            256-bit SSL
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            Güvenli Giriş
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            10K+ Kullanıcı
          </span>
        </div>
      </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.getElementById('togglePass')?.addEventListener('click', function() {
      const input = document.getElementById('password');
      input.type = input.type === 'password' ? 'text' : 'password';
    });
  </script>
</PublicLayout>
