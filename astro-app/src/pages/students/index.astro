---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach } from '../../lib/auth';
import prisma from '../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (!isCoach(user)) {
  return Astro.redirect('/dashboard');
}

// Eğitmenin öğrencilerini getir
const students = await prisma.user.findMany({
  where: { coachId: user.id, role: 'student' },
  include: {
    weightHistory: { orderBy: { date: 'desc' }, take: 1 },
    programs: { where: { status: 'active' } },
    dietPlans: { where: { active: true } },
    selectedPackage: true,
  },
  orderBy: { createdAt: 'desc' },
});
---

<MainLayout title="Öğrencilerim" activePage="students">
  <header class="px-6 lg:px-8 py-5 border-b border-border-default bg-bg-secondary/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">Öğrencilerim</h1>
        <p class="text-sm text-text-secondary mt-1">{students.length} öğrenci</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 text-text-muted"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Öğrenci ara..." class="input-field pl-10 w-full sm:w-[280px]" id="searchInput" />
        </div>
      </div>
    </div>
  </header>

  <div class="p-6 lg:p-8">
    <!-- Referral Code Banner -->
    <div class="card mb-8 border-accent-primary/20 bg-gradient-to-r from-accent-primary/5 to-accent-purple/5">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h3 class="font-semibold text-text-primary mb-1">Yeni Öğrenci Ekle</h3>
          <p class="text-sm text-text-secondary">Referans kodunuzu paylaşarak öğrenci ekleyin</p>
        </div>
        <div class="flex items-center gap-3">
          <code class="px-4 py-2 bg-bg-tertiary rounded-lg text-lg font-mono font-bold text-accent-primary tracking-wider">{user.referralCode}</code>
          <button onclick={`navigator.clipboard.writeText('${user.referralCode}'); this.innerHTML='<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>'; setTimeout(() => this.innerHTML='<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>', 2000)`} class="btn-secondary p-2" title="Kopyala">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>
      </div>
    </div>

    {students.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5" id="studentsGrid">
        {students.map(student => (
          <a href={`/students/${student.id}`} class="student-card block h-full group" data-name={student.name.toLowerCase()}>
            <div class="card h-full p-6 relative overflow-hidden transition-all group-hover:border-accent-primary/40">
              <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="relative">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-accent-primary to-accent-purple flex items-center justify-center text-xl font-bold text-white shrink-0">
                {student.name.charAt(0).toUpperCase()}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-text-primary text-lg truncate">{student.name}</h3>
                <p class="text-sm text-text-muted truncate">{student.email}</p>
                <p class="text-xs text-text-muted mt-1 truncate">Paket: {student.selectedPackage?.name || 'Seçilmedi'}</p>
              </div>
              <span class={`shrink-0 px-2 py-1 rounded-full text-xs font-semibold ${student.active ? 'bg-accent-green/15 text-accent-green' : 'bg-accent-red/15 text-accent-red'}`}>
                {student.active ? 'Aktif' : 'Pasif'}
              </span>
            </div>

            <div class="grid grid-cols-3 gap-3 mb-4">
              <div class="text-center p-3 rounded-lg bg-bg-tertiary">
                <div class="text-lg font-bold text-text-primary">{student.currentWeight || 'â€”'}</div>
                <div class="text-[10px] text-text-muted uppercase">Kilo</div>
              </div>
              <div class="text-center p-3 rounded-lg bg-bg-tertiary">
                <div class="text-lg font-bold text-text-primary">{student.targetWeight || 'â€”'}</div>
                <div class="text-[10px] text-text-muted uppercase">Hedef</div>
              </div>
              <div class="text-center p-3 rounded-lg bg-bg-tertiary">
                <div class="text-lg font-bold text-text-primary">{student.height || 'â€”'}</div>
                <div class="text-[10px] text-text-muted uppercase">Boy</div>
              </div>
            </div>

            <div class="flex items-center gap-2 flex-wrap mt-2">
              {student.programs.length > 0 ? (
                <span class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Program
                </span>
              ) : (
                <span class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-full bg-white/5 text-black border border-white/10 transition-all">
                  Program Yok
                </span>
              )}
              {student.dietPlans.length > 0 ? (
                <span class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20 transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Diyet
                </span>
              ) : (
                <span class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-full bg-white/5 text-black border border-white/10 transition-all">
                  Diyet Yok
                </span>
              )}
              {student.studentPaymentStatus === 'paid' ? (
                <span class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 transition-all">
                  Ücret Ödendi
                </span>
              ) : (
                <span class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-full bg-red-500/10 text-red-400 border border-red-500/20 transition-all">
                  Ödeme Bekleniyor
                </span>
              )}
            </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="w-20 h-20 rounded-3xl bg-bg-tertiary flex items-center justify-center mx-auto mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-xl font-bold text-text-primary mb-2">Henüz öğrenciniz yok</h3>
        <p class="text-text-secondary mb-6 max-w-md mx-auto">Referans kodunuzu öğrencilerinizle paylaşarak onları sisteme ekleyebilirsiniz.</p>
      </div>
    )}
  </div>

  <script is:inline>
    const searchInput = document.getElementById('searchInput');
    const studentCards = document.querySelectorAll('.student-card');

    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      studentCards.forEach(card => {
        const name = card.dataset.name;
        if (name.includes(query)) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  </script>
</MainLayout>



