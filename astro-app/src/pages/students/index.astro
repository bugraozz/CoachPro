---
import MainLayout from '../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach } from '../../lib/auth';
import prisma from '../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (!isCoach(user)) {
  return Astro.redirect('/dashboard');
}

// Eğitmenin öğrencilerini getir
const students = await prisma.user.findMany({
  where: { coachId: user.id, role: 'student' },
  include: {
    weightHistory: { orderBy: { date: 'desc' }, take: 1 },
    programs: { where: { status: 'active' } },
    dietPlans: { where: { active: true } },
    selectedPackage: true,
  },
  orderBy: { createdAt: 'desc' },
});
---

<MainLayout title="Öğrencilerim" activePage="students">
  <header class="section-header">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="animate-in">
        <h1>Öğrencilerim</h1>
        <p>{students.length} öğrenci</p>
      </div>
      <div class="flex items-center gap-3 animate-in-2">
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 text-text-muted"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Öğrenci ara..." class="input-field pl-10 w-full sm:w-[280px]" id="searchInput" />
        </div>
      </div>
    </div>
  </header>

  <div class="page-content">
    <!-- Referral Code Banner -->
    <div class="referral-banner mb-8 animate-in-1">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h3 class="font-bold text-text-primary mb-0.5">Yeni Öğrenci Ekle</h3>
          <p class="text-sm text-text-secondary">Referans kodunuzu paylaşarak öğrenci ekleyin</p>
        </div>
        <div class="flex items-center gap-3">
          <code class="px-5 py-2.5 bg-bg-card rounded-xl text-lg font-mono font-bold text-accent-primary tracking-wider border border-border-default shadow-sm">{user.referralCode}</code>
          <button onclick={`navigator.clipboard.writeText('${user.referralCode}'); this.innerHTML='<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>'; setTimeout(() => this.innerHTML='<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>', 2000)`} class="btn-secondary p-2.5" title="Kopyala">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>
      </div>
    </div>

    {students.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5" id="studentsGrid">
        {students.map((student, index) => (
          <a href={`/students/${student.id}`} class={`student-card block h-full group animate-in-${Math.min(index + 1, 6)}`} data-name={student.name.toLowerCase()}>
            <div class="card-accent h-full relative overflow-hidden transition-all group-hover:border-accent-primary/30" style={`--accent-stripe: ${student.active ? 'linear-gradient(90deg, #10b981, #34d399)' : 'linear-gradient(90deg, #94a3b8, #cbd5e1)'}`}>
              <div class="flex items-start gap-4 mb-4">
                <div class="w-13 h-13 rounded-xl bg-gradient-to-br from-accent-primary to-accent-purple flex items-center justify-center text-xl font-bold text-white shrink-0 shadow-md">
                  {student.name.charAt(0).toUpperCase()}
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-text-primary text-lg truncate group-hover:text-accent-primary transition-colors">{student.name}</h3>
                  <p class="text-sm text-text-muted truncate">{student.email}</p>
                  <p class="text-xs text-text-muted mt-0.5 truncate">Paket: {student.selectedPackage?.name || 'Seçilmedi'}</p>
                </div>
                <span class={`shrink-0 badge ${student.active ? 'badge-success' : 'badge-danger'}`}>
                  {student.active ? 'Aktif' : 'Pasif'}
                </span>
              </div>

              <div class="grid grid-cols-3 gap-3 mb-4">
                <div class="text-center p-3 rounded-lg bg-bg-tertiary/60 border border-border-default/50">
                  <div class="text-lg font-bold text-text-primary">{student.currentWeight || '—'}</div>
                  <div class="text-[10px] text-text-muted uppercase font-semibold tracking-wider">Kilo</div>
                </div>
                <div class="text-center p-3 rounded-lg bg-bg-tertiary/60 border border-border-default/50">
                  <div class="text-lg font-bold text-text-primary">{student.targetWeight || '—'}</div>
                  <div class="text-[10px] text-text-muted uppercase font-semibold tracking-wider">Hedef</div>
                </div>
                <div class="text-center p-3 rounded-lg bg-bg-tertiary/60 border border-border-default/50">
                  <div class="text-lg font-bold text-text-primary">{student.height || '—'}</div>
                  <div class="text-[10px] text-text-muted uppercase font-semibold tracking-wider">Boy</div>
                </div>
              </div>

              <div class="flex items-center gap-2 flex-wrap">
                {student.programs.length > 0 ? (
                  <span class="badge badge-success">Program</span>
                ) : (
                  <span class="badge" style="background:rgba(0,0,0,0.04);color:var(--color-text-muted);border:1px solid var(--color-border-default);border-radius:9999px">Program Yok</span>
                )}
                {student.dietPlans.length > 0 ? (
                  <span class="badge badge-info">Diyet</span>
                ) : (
                  <span class="badge" style="background:rgba(0,0,0,0.04);color:var(--color-text-muted);border:1px solid var(--color-border-default);border-radius:9999px">Diyet Yok</span>
                )}
                {student.studentPaymentStatus === 'paid' ? (
                  <span class="badge badge-success">Ödendi</span>
                ) : (
                  <span class="badge badge-warning">Ödeme Bekleniyor</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state animate-in">
        <div class="empty-state-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-muted"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <p class="empty-state-title">Henüz öğrenciniz yok</p>
        <p class="empty-state-description">Referans kodunuzu öğrencilerinizle paylaşarak onları sisteme ekleyebilirsiniz.</p>
      </div>
    )}
  </div>

  <script is:inline>
    const searchInput = document.getElementById('searchInput');
    const studentCards = document.querySelectorAll('.student-card');

    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      studentCards.forEach(card => {
        const name = card.dataset.name;
        if (name.includes(query)) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  </script>
</MainLayout>
