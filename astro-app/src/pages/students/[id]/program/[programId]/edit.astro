---
import MainLayout from '../../../../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach } from '../../../../../lib/auth';
import prisma from '../../../../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (!isCoach(user)) {
  return Astro.redirect('/dashboard');
}

const { id, programId } = Astro.params;

const student = await prisma.user.findFirst({
  where: { id, coachId: user.id, role: 'student' },
  select: { id: true, name: true },
});

if (!student) {
  return Astro.redirect('/students');
}

const program = await prisma.program.findFirst({
  where: { id: programId, userId: student.id },
  include: {
    days: {
      include: { exercises: { orderBy: { order: 'asc' } } },
      orderBy: { order: 'asc' },
    },
  },
});

if (!program) {
  return Astro.redirect(`/students/${id}`);
}

const programJson = JSON.stringify({
  id: program.id,
  name: program.name,
  status: program.status,
  days: program.days.map(d => ({
    dayName: d.dayName,
    order: d.order,
    exercises: d.exercises.map(e => ({
      name: e.name,
      muscleGroup: e.muscleGroup,
      sets: e.sets,
      reps: e.reps,
      weight: e.weight,
      restSeconds: e.restSeconds,
      notes: e.notes,
      order: e.order,
    })),
  })),
});
---

<MainLayout title={`Program Düzenle - ${student.name}`} activePage="students">
  <header class="px-6 lg:px-8 py-5 border-b border-border-default bg-bg-secondary/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4">
        <a href={`/students/${student.id}`} class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div>
          <h1 class="text-2xl font-bold text-text-primary">Programı Düzenle</h1>
          <p class="text-sm text-text-secondary mt-0.5">{student.name} - {program.name}</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button id="deleteBtn" class="px-4 py-2.5 rounded-xl bg-accent-red/10 text-accent-red font-medium text-sm hover:bg-accent-red/20 transition-colors flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          Sil
        </button>
        <button id="saveBtn" class="btn-primary" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Kaydet
        </button>
      </div>
    </div>
  </header>

  <div class="p-6 lg:p-8">
    <!-- Program Config -->
    <div class="card mb-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="label mb-2">Program Adı</label>
          <input type="text" id="programName" class="input-field" value={program.name} />
        </div>
        <div>
          <label class="label mb-2">Kategori</label>
          <select id="programCategory" class="input-field">
            <option value="Fitness" selected={program.category === 'Fitness' || !program.category}>Fitness / Vücut Geliştirme</option>
            <option value="Yüzme" selected={program.category === 'Yüzme'}>Yüzme</option>
            <option value="Pilates" selected={program.category === 'Pilates'}>Pilates</option>
            <option value="Kardiyo" selected={program.category === 'Kardiyo'}>Kardiyo / Koşu</option>
            <option value="Yoga" selected={program.category === 'Yoga'}>Yoga</option>
            <option value="Diğer" selected={program.category === 'Diğer'}>Diğer</option>
          </select>
        </div>
        <div>
          <label class="label mb-2">Durum</label>
          <select id="programStatus" class="input-field">
            <option value="active" selected={program.status === 'active'}>Aktif</option>
            <option value="inactive" selected={program.status === 'inactive'}>Pasif</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Days Container -->
    <div id="daysContainer" class="space-y-6"></div>

    <!-- Add Day Button -->
    <button id="addDayBtn" class="w-full mt-6 py-4 border-2 border-dashed border-border-default rounded-xl text-text-muted hover:text-accent-primary hover:border-accent-primary transition-all flex items-center justify-center gap-2 text-sm font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Gün Ekle
    </button>

    <div id="statusMsg" class="hidden mt-6 p-4 rounded-xl text-sm"></div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="deleteModal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-bg-card border border-border-default rounded-2xl p-6 w-full max-w-sm text-center">
      <div class="w-14 h-14 rounded-full bg-accent-red/10 flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-red"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
      </div>
      <h3 class="text-lg font-bold text-text-primary mb-2">Programı Sil</h3>
      <p class="text-sm text-text-secondary mb-6">Bu program ve tüm günleri/egzersizleri kalıcı olarak silinecek.</p>
      <div class="flex gap-3">
        <button id="cancelDel" class="btn-secondary flex-1">İptal</button>
        <button id="confirmDel" class="flex-1 px-4 py-2.5 rounded-xl bg-accent-red text-white font-medium text-sm hover:bg-accent-red/90 transition-colors">Sil</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ studentId: student.id, programId: program.id, programJson }}>
    const muscleGroups = ['Göğüs', 'Sırt', 'Omuz', 'Biceps', 'Triceps', 'Bacak', 'Kalça', 'Karın', 'Ön Kol', 'Trapez', 'Baldır', 'Tüm Vücut', 'Kardiyo'];
    const existingProgram = JSON.parse(programJson);
    let dayCounter = 0;

    function createExerciseRow(ex = {}) {
      return `
        <div class="exercise-row grid grid-cols-12 gap-2 items-start p-3 rounded-lg bg-bg-tertiary/50 border border-border-default/50" draggable="true">
          <div class="col-span-12 sm:col-span-3">
            <input type="text" placeholder="Egzersiz adı" class="input-field text-sm ex-name" value="${ex.name || ''}" />
          </div>
          <div class="col-span-6 sm:col-span-2">
            <select class="input-field text-sm ex-muscle">
              <option value="">Kas Grubu</option>
              ${muscleGroups.map(m => `<option value="${m}" ${ex.muscleGroup === m ? 'selected' : ''}>${m}</option>`).join('')}
            </select>
          </div>
          <div class="col-span-3 sm:col-span-1">
            <input type="number" placeholder="Set" class="input-field text-sm text-center ex-sets" min="1" value="${ex.sets || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-2">
            <input type="text" placeholder="Tekrar" class="input-field text-sm text-center ex-reps" value="${ex.reps || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-1">
            <input type="number" placeholder="kg" class="input-field text-sm text-center ex-weight" step="0.5" min="0" value="${ex.weight || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-1">
            <input type="number" placeholder="sn" class="input-field text-sm text-center ex-rest" min="0" step="5" value="${ex.restSeconds || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-1">
            <input type="text" placeholder="Not" class="input-field text-sm ex-notes" value="${ex.notes || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-1 flex items-center justify-end gap-1">
            <button class="move-ex-up p-1 rounded hover:bg-bg-tertiary text-text-muted hover:text-text-primary transition-colors" title="Yukarı">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6"/></svg>
            </button>
            <button class="move-ex-down p-1 rounded hover:bg-bg-tertiary text-text-muted hover:text-text-primary transition-colors" title="Aşağı">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <button class="remove-ex p-1 rounded hover:bg-accent-red/10 text-text-muted hover:text-accent-red transition-colors" title="Sil">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        </div>
      `;
    }

    function createDayCard(dayName, exercises = []) {
      const idx = dayCounter++;
      const div = document.createElement('div');
      div.className = 'card day-card';
      div.dataset.day = idx;
      div.innerHTML = `
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="day-number w-10 h-10 rounded-xl bg-accent-primary/10 flex items-center justify-center text-sm font-bold text-accent-primary">${idx + 1}</span>
            <input type="text" value="${dayName}" class="day-name text-lg font-semibold text-text-primary bg-transparent border-none outline-none focus:ring-0 w-[200px]" />
          </div>
          <div class="flex items-center gap-2">
            <span class="exercise-count text-xs text-text-muted bg-bg-tertiary px-2 py-1 rounded">0 egzersiz</span>
            <button class="remove-day p-2 rounded-lg hover:bg-accent-red/10 text-text-muted hover:text-accent-red transition-all" title="Günü Sil">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </button>
          </div>
        </div>
        <div class="hidden sm:grid grid-cols-12 gap-2 px-3 mb-2 text-[10px] font-semibold text-text-muted uppercase tracking-wider">
          <div class="col-span-3">Egzersiz</div>
          <div class="col-span-2">Kas Grubu</div>
          <div class="col-span-1 text-center">Set</div>
          <div class="col-span-2 text-center">Tekrar</div>
          <div class="col-span-1 text-center">Ağırlık</div>
          <div class="col-span-1 text-center">Dinlenme</div>
          <div class="col-span-1 text-center">Not</div>
          <div class="col-span-1"></div>
        </div>
        <div class="exercises-container space-y-2">
          ${exercises.length > 0 ? exercises.map(ex => createExerciseRow(ex)).join('') : createExerciseRow()}
        </div>
        <button class="add-exercise-btn w-full mt-3 py-2.5 border border-dashed border-border-default rounded-lg text-text-muted hover:text-accent-green hover:border-accent-green transition-all flex items-center justify-center gap-2 text-xs font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Egzersiz Ekle
        </button>
      `;
      return div;
    }

    function bindDayEvents(card) {
      card.querySelector('.remove-day').addEventListener('click', () => {
        card.remove();
        updateDayNumbers();
        updateSaveBtn();
      });
      card.querySelector('.add-exercise-btn').addEventListener('click', () => {
        const container = card.querySelector('.exercises-container');
        container.insertAdjacentHTML('beforeend', createExerciseRow());
        bindExerciseEvents(card);
        updateExerciseCount(card);
      });
      bindExerciseEvents(card);
      updateExerciseCount(card);
    }

    function bindExerciseEvents(card) {
      const container = card.querySelector('.exercises-container');
      container.querySelectorAll('.remove-ex').forEach(btn => {
        btn.onclick = () => {
          const rows = container.querySelectorAll('.exercise-row');
          if (rows.length > 1) {
            btn.closest('.exercise-row').remove();
            updateExerciseCount(card);
            updateSaveBtn();
          }
        };
      });
      container.querySelectorAll('.move-ex-up').forEach(btn => {
        btn.onclick = () => {
          const row = btn.closest('.exercise-row');
          const prev = row.previousElementSibling;
          if (prev) container.insertBefore(row, prev);
        };
      });
      container.querySelectorAll('.move-ex-down').forEach(btn => {
        btn.onclick = () => {
          const row = btn.closest('.exercise-row');
          const next = row.nextElementSibling;
          if (next) container.insertBefore(next, row);
        };
      });
      container.querySelectorAll('input, select').forEach(input => {
        input.addEventListener('input', () => { updateExerciseCount(card); updateSaveBtn(); });
      });
    }

    function updateExerciseCount(card) {
      let count = 0;
      card.querySelectorAll('.ex-name').forEach(input => { if (input.value.trim()) count++; });
      card.querySelector('.exercise-count').textContent = `${count} egzersiz`;
    }

    function updateDayNumbers() {
      document.querySelectorAll('.day-card').forEach((card, idx) => {
        card.querySelector('.day-number').textContent = idx + 1;
      });
    }

    function updateSaveBtn() {
      const name = document.getElementById('programName').value.trim();
      const dayCards = document.querySelectorAll('.day-card');
      let hasExercise = false;
      dayCards.forEach(card => {
        card.querySelectorAll('.ex-name').forEach(input => { if (input.value.trim()) hasExercise = true; });
      });
      document.getElementById('saveBtn').disabled = !(name && dayCards.length > 0 && hasExercise);
    }

    // Load existing data
    const container = document.getElementById('daysContainer');
    existingProgram.days.forEach(day => {
      const card = createDayCard(day.dayName, day.exercises);
      container.appendChild(card);
      bindDayEvents(card);
    });
    if (existingProgram.days.length === 0) {
      const card = createDayCard('Pazartesi', []);
      container.appendChild(card);
      bindDayEvents(card);
    }
    updateSaveBtn();

    document.getElementById('programName').addEventListener('input', updateSaveBtn);
    document.getElementById('addDayBtn').addEventListener('click', () => {
      const names = ['Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi','Pazar'];
      const existingCount = document.querySelectorAll('.day-card').length;
      const card = createDayCard(names[existingCount % 7] || `Gün ${existingCount + 1}`, []);
      container.appendChild(card);
      bindDayEvents(card);
      updateSaveBtn();
    });

    // Save
    document.getElementById('saveBtn').addEventListener('click', async () => {
      const btn = document.getElementById('saveBtn');
      btn.disabled = true;
      btn.innerHTML = '<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Kaydediliyor...';

      const name = document.getElementById('programName').value.trim();
      const status = document.getElementById('programStatus').value;
      const category = document.getElementById('programCategory').value;
      const dayCards = document.querySelectorAll('.day-card');
      const days = [];

      dayCards.forEach((card, dayIdx) => {
        const dayName = card.querySelector('.day-name').value.trim() || `Gün ${dayIdx + 1}`;
        const exercises = [];
        card.querySelectorAll('.exercise-row').forEach((row, exIdx) => {
          const exName = row.querySelector('.ex-name').value.trim();
          if (!exName) return;
          exercises.push({
            name: exName,
            muscleGroup: row.querySelector('.ex-muscle').value || 'Genel',
            sets: parseInt(row.querySelector('.ex-sets').value) || 3,
            reps: row.querySelector('.ex-reps').value || '10',
            weight: parseFloat(row.querySelector('.ex-weight').value) || null,
            restSeconds: parseInt(row.querySelector('.ex-rest').value) || null,
            notes: row.querySelector('.ex-notes').value || null,
            order: exIdx,
          });
        });
        days.push({ dayName, order: dayIdx, exercises });
      });

      try {
        const res = await fetch(`/api/programs/${programId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, status, category, days }),
        });
        if (res.ok) {
          const msg = document.getElementById('statusMsg');
          msg.className = 'mt-6 p-4 rounded-xl text-sm bg-accent-green/10 text-accent-green border border-accent-green/20';
          msg.textContent = 'Program başarıyla güncellendi! Yönlendiriliyor...';
          msg.classList.remove('hidden');
          setTimeout(() => window.location.href = `/students/${studentId}`, 1200);
        } else {
          const data = await res.json();
          const msg = document.getElementById('statusMsg');
          msg.className = 'mt-6 p-4 rounded-xl text-sm bg-accent-red/10 text-accent-red border border-accent-red/20';
          msg.textContent = data.error || 'Güncelleme başarısız';
          msg.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Kaydet';
        }
      } catch {
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Kaydet';
      }
    });

    // Delete
    document.getElementById('deleteBtn').addEventListener('click', () => {
      document.getElementById('deleteModal').classList.remove('hidden');
    });
    document.getElementById('cancelDel').addEventListener('click', () => {
      document.getElementById('deleteModal').classList.add('hidden');
    });
    document.getElementById('confirmDel').addEventListener('click', async () => {
      const btn = document.getElementById('confirmDel');
      btn.textContent = 'Siliniyor...';
      btn.disabled = true;
      try {
        const res = await fetch(`/api/programs/${programId}`, { method: 'DELETE' });
        if (res.ok) {
          window.location.href = `/students/${studentId}`;
        } else {
          alert('Silme başarısız');
          btn.textContent = 'Sil';
          btn.disabled = false;
        }
      } catch {
        alert('Bir hata oluştu');
        btn.textContent = 'Sil';
        btn.disabled = false;
      }
    });
    document.getElementById('deleteModal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) document.getElementById('deleteModal').classList.add('hidden');
    });
  </script>
</MainLayout>
