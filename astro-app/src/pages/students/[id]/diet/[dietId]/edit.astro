---
import MainLayout from '../../../../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach } from '../../../../../lib/auth';
import prisma from '../../../../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (!isCoach(user)) {
  return Astro.redirect('/dashboard');
}

const { id, dietId } = Astro.params;

const student = await prisma.user.findFirst({
  where: { id, coachId: user.id, role: 'student' },
  select: { id: true, name: true },
});

if (!student) {
  return Astro.redirect('/students');
}

const diet = await prisma.dietPlan.findFirst({
  where: { id: dietId, userId: student.id },
  include: {
    meals: {
      include: { foods: true },
      orderBy: { order: 'asc' },
    },
  },
});

if (!diet) {
  return Astro.redirect(`/students/${id}`);
}

const dietJson = JSON.stringify({
  id: diet.id,
  name: diet.name,
  active: diet.active,
  dailyCalorieTarget: diet.dailyCalorieTarget,
  proteinTarget: diet.proteinTarget,
  carbsTarget: diet.carbsTarget,
  fatTarget: diet.fatTarget,
  waterTarget: diet.waterTarget,
  meals: diet.meals.map(m => ({
    name: m.name,
    order: m.order,
    foods: m.foods.map(f => ({
      name: f.name,
      amount: f.amount,
      unit: f.unit,
      calories: f.calories,
      protein: f.protein,
      carbs: f.carbs,
      fat: f.fat,
    })),
  })),
});
---

<MainLayout title={`Diyet Düzenle - ${student.name}`} activePage="students">
  <header class="px-6 lg:px-8 py-5 border-b border-border-default bg-bg-secondary/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4">
        <a href={`/students/${student.id}`} class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div>
          <h1 class="text-2xl font-bold text-text-primary">Diyeti Düzenle</h1>
          <p class="text-sm text-text-secondary mt-0.5">{student.name} - {diet.name}</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button id="deleteBtn" class="px-4 py-2.5 rounded-xl bg-accent-red/10 text-accent-red font-medium text-sm hover:bg-accent-red/20 transition-colors flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          Sil
        </button>
        <button id="saveBtn" class="btn-primary" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Kaydet
        </button>
      </div>
    </div>
  </header>

  <div class="p-6 lg:p-8">
    <!-- Diet Info -->
    <div class="card mb-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="label mb-2">Diyet Adı</label>
          <input type="text" id="dietName" class="input-field" value={diet.name} />
        </div>
        <div>
          <label class="label mb-2">Durum</label>
          <select id="dietStatus" class="input-field">
            <option value="true" selected={diet.active}>Aktif</option>
            <option value="false" selected={!diet.active}>Pasif</option>
          </select>
        </div>
      </div>
      <h4 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-3">Günlük Makro Hedefleri</h4>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
        <div>
          <label class="label mb-1 text-xs">Kalori (kcal)</label>
          <input type="number" id="calorieTarget" class="input-field text-center" value={diet.dailyCalorieTarget} min="0" />
        </div>
        <div>
          <label class="label mb-1 text-xs">Protein (g)</label>
          <input type="number" id="proteinTarget" class="input-field text-center" value={diet.proteinTarget} min="0" />
        </div>
        <div>
          <label class="label mb-1 text-xs">Karbonhidrat (g)</label>
          <input type="number" id="carbsTarget" class="input-field text-center" value={diet.carbsTarget} min="0" />
        </div>
        <div>
          <label class="label mb-1 text-xs">Yağ (g)</label>
          <input type="number" id="fatTarget" class="input-field text-center" value={diet.fatTarget} min="0" />
        </div>
        <div>
          <label class="label mb-1 text-xs">Su (ml)</label>
          <input type="number" id="waterTarget" class="input-field text-center" value={diet.waterTarget || 3000} min="0" step="250" />
        </div>
      </div>
    </div>

    <!-- Meals Container -->
    <div id="mealsContainer" class="space-y-6"></div>

    <!-- Add Meal Button -->
    <button id="addMealBtn" class="w-full mt-6 py-4 border-2 border-dashed border-border-default rounded-xl text-text-muted hover:text-accent-primary hover:border-accent-primary transition-all flex items-center justify-center gap-2 text-sm font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Öğün Ekle
    </button>

    <div id="statusMsg" class="hidden mt-6 p-4 rounded-xl text-sm"></div>
  </div>

  <!-- Delete Modal -->
  <div id="deleteModal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-bg-card border border-border-default rounded-2xl p-6 w-full max-w-sm text-center">
      <div class="w-14 h-14 rounded-full bg-accent-red/10 flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-red"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
      </div>
      <h3 class="text-lg font-bold text-text-primary mb-2">Diyeti Sil</h3>
      <p class="text-sm text-text-secondary mb-6">Bu diyet planı ve tüm öğünleri kalıcı olarak silinecek.</p>
      <div class="flex gap-3">
        <button id="cancelDel" class="btn-secondary flex-1">İptal</button>
        <button id="confirmDel" class="flex-1 px-4 py-2.5 rounded-xl bg-accent-red text-white font-medium text-sm hover:bg-accent-red/90 transition-colors">Sil</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ studentId: student.id, dietId: diet.id, dietJson }}>
    const existingDiet = JSON.parse(dietJson);
    let mealCounter = 0;

    function createFoodRow(food = {}) {
      return `
        <div class="food-row grid grid-cols-12 gap-2 items-start p-2 rounded-lg bg-bg-tertiary/50 border border-border-default/50">
          <div class="col-span-12 sm:col-span-3">
            <input type="text" placeholder="Besin adı" class="input-field text-sm fd-name" value="${food.name || ''}" />
          </div>
          <div class="col-span-4 sm:col-span-1">
            <input type="number" placeholder="Mik." class="input-field text-sm text-center fd-amount" min="0" step="0.5" value="${food.amount || ''}" />
          </div>
          <div class="col-span-4 sm:col-span-1">
            <select class="input-field text-sm fd-unit">
              <option value="g" ${food.unit === 'g' ? 'selected' : ''}>g</option>
              <option value="ml" ${food.unit === 'ml' ? 'selected' : ''}>ml</option>
              <option value="porsiyon" ${food.unit === 'porsiyon' ? 'selected' : ''}>porsiyon</option>
              <option value="adet" ${food.unit === 'adet' ? 'selected' : ''}>adet</option>
              <option value="yemek kaşığı" ${food.unit === 'yemek kaşığı' ? 'selected' : ''}>yk</option>
              <option value="çay kaşığı" ${food.unit === 'çay kaşığı' ? 'selected' : ''}>çk</option>
              <option value="su bardağı" ${food.unit === 'su bardağı' ? 'selected' : ''}>sb</option>
            </select>
          </div>
          <div class="col-span-4 sm:col-span-1">
            <input type="number" placeholder="kcal" class="input-field text-sm text-center fd-cal" min="0" value="${food.calories || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-2">
            <input type="number" placeholder="Protein" class="input-field text-sm text-center fd-pro" min="0" step="0.1" value="${food.protein || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-2">
            <input type="number" placeholder="Karb" class="input-field text-sm text-center fd-carb" min="0" step="0.1" value="${food.carbs || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-1">
            <input type="number" placeholder="Yağ" class="input-field text-sm text-center fd-fat" min="0" step="0.1" value="${food.fat || ''}" />
          </div>
          <div class="col-span-3 sm:col-span-1 flex items-center justify-end">
            <button class="remove-food p-1.5 rounded hover:bg-accent-red/10 text-text-muted hover:text-accent-red transition-colors" title="Sil">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        </div>
      `;
    }

    function createMealCard(mealName, foods = []) {
      const idx = mealCounter++;
      const div = document.createElement('div');
      div.className = 'card meal-card';
      div.dataset.meal = idx;
      div.innerHTML = `
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="meal-number w-10 h-10 rounded-xl bg-accent-cyan/10 flex items-center justify-center text-sm font-bold text-accent-cyan">${idx + 1}</span>
            <input type="text" value="${mealName}" class="meal-name text-lg font-semibold text-text-primary bg-transparent border-none outline-none focus:ring-0 w-[200px]" />
          </div>
          <div class="flex items-center gap-2">
            <span class="meal-kcal text-xs text-text-muted bg-bg-tertiary px-2 py-1 rounded">0 kcal</span>
            <button class="remove-meal p-2 rounded-lg hover:bg-accent-red/10 text-text-muted hover:text-accent-red transition-all" title="Öğünü Sil">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </button>
          </div>
        </div>
        <div class="hidden sm:grid grid-cols-12 gap-2 px-2 mb-2 text-[10px] font-semibold text-text-muted uppercase tracking-wider">
          <div class="col-span-3">Besin</div>
          <div class="col-span-1 text-center">Miktar</div>
          <div class="col-span-1 text-center">Birim</div>
          <div class="col-span-1 text-center">Kalori</div>
          <div class="col-span-2 text-center">Protein (g)</div>
          <div class="col-span-2 text-center">Karb (g)</div>
          <div class="col-span-1 text-center">Yağ (g)</div>
          <div class="col-span-1"></div>
        </div>
        <div class="foods-container space-y-2">
          ${foods.length > 0 ? foods.map(f => createFoodRow(f)).join('') : createFoodRow()}
        </div>
        <button class="add-food-btn w-full mt-3 py-2.5 border border-dashed border-border-default rounded-lg text-text-muted hover:text-accent-green hover:border-accent-green transition-all flex items-center justify-center gap-2 text-xs font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Besin Ekle
        </button>
      `;
      return div;
    }

    function bindMealEvents(card) {
      card.querySelector('.remove-meal').addEventListener('click', () => {
        card.remove();
        updateMealNumbers();
        updateSaveBtn();
      });
      card.querySelector('.add-food-btn').addEventListener('click', () => {
        const container = card.querySelector('.foods-container');
        container.insertAdjacentHTML('beforeend', createFoodRow());
        bindFoodEvents(card);
        updateMealKcal(card);
      });
      bindFoodEvents(card);
      updateMealKcal(card);
    }

    function bindFoodEvents(card) {
      const container = card.querySelector('.foods-container');
      container.querySelectorAll('.remove-food').forEach(btn => {
        btn.onclick = () => {
          const rows = container.querySelectorAll('.food-row');
          if (rows.length > 1) {
            btn.closest('.food-row').remove();
            updateMealKcal(card);
            updateSaveBtn();
          }
        };
      });
      container.querySelectorAll('input, select').forEach(input => {
        input.addEventListener('input', () => {
          // Auto-calc calories from macros
          const row = input.closest('.food-row');
          if (row && (input.classList.contains('fd-pro') || input.classList.contains('fd-carb') || input.classList.contains('fd-fat'))) {
            const p = parseFloat(row.querySelector('.fd-pro').value) || 0;
            const c = parseFloat(row.querySelector('.fd-carb').value) || 0;
            const f = parseFloat(row.querySelector('.fd-fat').value) || 0;
            const calInput = row.querySelector('.fd-cal');
            if (!calInput.dataset.manual) {
              calInput.value = Math.round(p * 4 + c * 4 + f * 9);
            }
          }
          if (input.classList.contains('fd-cal')) {
            input.dataset.manual = 'true';
          }
          updateMealKcal(card);
          updateSaveBtn();
        });
      });
    }

    function updateMealKcal(card) {
      let totalKcal = 0;
      card.querySelectorAll('.fd-cal').forEach(input => {
        totalKcal += parseInt(input.value) || 0;
      });
      card.querySelector('.meal-kcal').textContent = `${totalKcal} kcal`;
    }

    function updateMealNumbers() {
      document.querySelectorAll('.meal-card').forEach((card, idx) => {
        card.querySelector('.meal-number').textContent = idx + 1;
      });
    }

    function updateSaveBtn() {
      const name = document.getElementById('dietName').value.trim();
      const mealCards = document.querySelectorAll('.meal-card');
      let hasFood = false;
      mealCards.forEach(card => {
        card.querySelectorAll('.fd-name').forEach(input => { if (input.value.trim()) hasFood = true; });
      });
      document.getElementById('saveBtn').disabled = !(name && mealCards.length > 0 && hasFood);
    }

    // Load existing data
    const container = document.getElementById('mealsContainer');
    existingDiet.meals.forEach(meal => {
      const card = createMealCard(meal.name, meal.foods);
      container.appendChild(card);
      bindMealEvents(card);
    });
    if (existingDiet.meals.length === 0) {
      const card = createMealCard('Kahvaltı', []);
      container.appendChild(card);
      bindMealEvents(card);
    }
    updateSaveBtn();

    document.getElementById('dietName').addEventListener('input', updateSaveBtn);
    document.querySelectorAll('#calorieTarget, #proteinTarget, #carbsTarget, #fatTarget, #waterTarget').forEach(input => {
      input.addEventListener('input', updateSaveBtn);
    });

    document.getElementById('addMealBtn').addEventListener('click', () => {
      const defaults = ['Kahvaltı', 'Ara Öğün', 'Öğle Yemeği', 'İkindi', 'Akşam Yemeği', 'Gece'];
      const count = document.querySelectorAll('.meal-card').length;
      const card = createMealCard(defaults[count % defaults.length] || `Öğün ${count + 1}`, []);
      container.appendChild(card);
      bindMealEvents(card);
      updateSaveBtn();
    });

    // Save
    document.getElementById('saveBtn').addEventListener('click', async () => {
      const btn = document.getElementById('saveBtn');
      btn.disabled = true;
      btn.innerHTML = '<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Kaydediliyor...';

      const meals = [];
      document.querySelectorAll('.meal-card').forEach((card, mealIdx) => {
        const mealName = card.querySelector('.meal-name').value.trim() || `Öğün ${mealIdx + 1}`;
        const foods = [];
        card.querySelectorAll('.food-row').forEach(row => {
          const foodName = row.querySelector('.fd-name').value.trim();
          if (!foodName) return;
          foods.push({
            name: foodName,
            amount: parseFloat(row.querySelector('.fd-amount').value) || 0,
            unit: row.querySelector('.fd-unit').value || 'g',
            calories: parseInt(row.querySelector('.fd-cal').value) || 0,
            protein: parseFloat(row.querySelector('.fd-pro').value) || 0,
            carbs: parseFloat(row.querySelector('.fd-carb').value) || 0,
            fat: parseFloat(row.querySelector('.fd-fat').value) || 0,
          });
        });
        meals.push({ name: mealName, order: mealIdx, foods });
      });

      const payload = {
        name: document.getElementById('dietName').value.trim(),
        active: document.getElementById('dietStatus').value === 'true',
        dailyCalorieTarget: parseInt(document.getElementById('calorieTarget').value) || 2000,
        proteinTarget: parseInt(document.getElementById('proteinTarget').value) || 150,
        carbsTarget: parseInt(document.getElementById('carbsTarget').value) || 200,
        fatTarget: parseInt(document.getElementById('fatTarget').value) || 70,
        waterTarget: parseInt(document.getElementById('waterTarget').value) || 3000,
        meals,
      };

      try {
        const res = await fetch(`/api/diet/${dietId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (res.ok) {
          const msg = document.getElementById('statusMsg');
          msg.className = 'mt-6 p-4 rounded-xl text-sm bg-accent-green/10 text-accent-green border border-accent-green/20';
          msg.textContent = 'Diyet başarıyla güncellendi! Yönlendiriliyor...';
          msg.classList.remove('hidden');
          setTimeout(() => window.location.href = `/students/${studentId}`, 1200);
        } else {
          const data = await res.json();
          const msg = document.getElementById('statusMsg');
          msg.className = 'mt-6 p-4 rounded-xl text-sm bg-accent-red/10 text-accent-red border border-accent-red/20';
          msg.textContent = data.error || 'Güncelleme başarısız';
          msg.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Kaydet';
        }
      } catch {
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Kaydet';
      }
    });

    // Delete
    document.getElementById('deleteBtn').addEventListener('click', () => {
      document.getElementById('deleteModal').classList.remove('hidden');
    });
    document.getElementById('cancelDel').addEventListener('click', () => {
      document.getElementById('deleteModal').classList.add('hidden');
    });
    document.getElementById('confirmDel').addEventListener('click', async () => {
      const btn = document.getElementById('confirmDel');
      btn.textContent = 'Siliniyor...';
      btn.disabled = true;
      try {
        const res = await fetch(`/api/diet/${dietId}`, { method: 'DELETE' });
        if (res.ok) {
          window.location.href = `/students/${studentId}`;
        } else {
          alert('Silme başarısız');
          btn.textContent = 'Sil';
          btn.disabled = false;
        }
      } catch {
        alert('Bir hata oluştu');
        btn.textContent = 'Sil';
        btn.disabled = false;
      }
    });
    document.getElementById('deleteModal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) document.getElementById('deleteModal').classList.add('hidden');
    });
  </script>
</MainLayout>
