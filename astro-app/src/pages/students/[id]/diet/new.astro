---
import MainLayout from '../../../../layouts/MainLayout.astro';
import { getUserFromRequest, isCoach } from '../../../../lib/auth';
import prisma from '../../../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (!isCoach(user)) {
  return Astro.redirect('/dashboard');
}

const { id } = Astro.params;

const student = await prisma.user.findFirst({
  where: { id, coachId: user.id, role: 'student' },
  select: { id: true, name: true, currentWeight: true, targetWeight: true, height: true, age: true },
});

if (!student) {
  return Astro.redirect('/students');
}
---

<MainLayout title={`Diyet Oluştur - ${student.name}`} activePage="students">
  <header class="px-6 lg:px-8 py-5 border-b border-border-default bg-bg-secondary/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4">
        <a href={`/students/${student.id}`} class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div>
          <h1 class="text-2xl font-bold text-text-primary">Yeni Diyet Planı</h1>
          <p class="text-sm text-text-secondary mt-0.5">{student.name} için beslenme programı</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button id="saveBtn" class="btn-primary" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Diyeti Kaydet
        </button>
      </div>
    </div>
  </header>

  <div class="p-6 lg:p-8">
    <!-- Diet Info -->
    <div class="card mb-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
          <label class="label mb-2">Plan Adı</label>
          <input type="text" id="dietName" class="input-field" placeholder="Örn: Kilo Verme Diyeti, Kas Yapma Diyeti, Hacim Dönemi..." />
        </div>
        <div>
          <label class="label mb-2">Günlük Su Hedefi (ml)</label>
          <input type="number" id="waterTarget" class="input-field" value="3000" step="250" min="0" />
        </div>
      </div>
    </div>

    <!-- Macro Targets -->
    <div class="card mb-6">
      <h3 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-green"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Günlük Makro Hedefleri
      </h3>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div>
          <label class="label mb-2">Kalori (kcal)</label>
          <input type="number" id="calorieTarget" class="input-field text-center text-lg font-bold" value="2000" min="0" />
        </div>
        <div>
          <label class="label mb-2">Protein (g)</label>
          <input type="number" id="proteinTarget" class="input-field text-center text-lg font-bold" value="150" min="0" />
        </div>
        <div>
          <label class="label mb-2">Karbonhidrat (g)</label>
          <input type="number" id="carbsTarget" class="input-field text-center text-lg font-bold" value="200" min="0" />
        </div>
        <div>
          <label class="label mb-2">Yağ (g)</label>
          <input type="number" id="fatTarget" class="input-field text-center text-lg font-bold" value="70" min="0" />
        </div>
      </div>
      <div class="mt-3 text-xs text-text-muted text-center" id="macroCalc">
        Hesaplanan: <span id="calcCalories">0</span> kcal (P×4 + K×4 + Y×9)
      </div>
    </div>

    <!-- Meals Container -->
    <div id="mealsContainer" class="space-y-6">
      <!-- Meals will be added here dynamically -->
    </div>

    <!-- Add Meal Button -->
    <button id="addMealBtn" class="w-full mt-6 py-4 border-2 border-dashed border-border-default rounded-xl text-text-muted hover:text-accent-cyan hover:border-accent-cyan transition-all flex items-center justify-center gap-2 text-sm font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Öğün Ekle
    </button>

    <!-- Status Message -->
    <div id="statusMsg" class="hidden mt-6 p-4 rounded-xl text-sm"></div>
  </div>

  <script is:inline define:vars={{ studentId: student.id }}>
    const defaultMeals = ['Kahvaltı', 'Ara Öğün 1', 'Öğle Yemeği', 'Ara Öğün 2', 'Akşam Yemeği', 'Gece Atıştırma'];
    const units = ['g', 'ml', 'adet', 'porsiyon', 'dilim', 'kaşık', 'bardak', 'avuç'];
    
    let mealCounter = 0;

    function createFoodRow() {
      return `
        <div class="food-row grid grid-cols-12 gap-2 items-start p-3 rounded-lg bg-bg-tertiary/50 border border-border-default/50">
          <div class="col-span-12 sm:col-span-3">
            <input type="text" placeholder="Besin adı" class="input-field text-sm food-name" />
          </div>
          <div class="col-span-4 sm:col-span-1">
            <input type="number" placeholder="Miktar" class="input-field text-sm text-center food-amount" min="0" step="0.1" />
          </div>
          <div class="col-span-4 sm:col-span-1">
            <select class="input-field text-sm food-unit">
              ${units.map(u => `<option value="${u}">${u}</option>`).join('')}
            </select>
          </div>
          <div class="col-span-4 sm:col-span-1">
            <input type="number" placeholder="kcal" class="input-field text-sm text-center food-calories" min="0" />
          </div>
          <div class="col-span-3 sm:col-span-2">
            <input type="number" placeholder="Protein" class="input-field text-sm text-center food-protein" min="0" step="0.1" />
          </div>
          <div class="col-span-3 sm:col-span-2">
            <input type="number" placeholder="Karb" class="input-field text-sm text-center food-carbs" min="0" step="0.1" />
          </div>
          <div class="col-span-3 sm:col-span-1">
            <input type="number" placeholder="Yağ" class="input-field text-sm text-center food-fat" min="0" step="0.1" />
          </div>
          <div class="col-span-3 sm:col-span-1 flex items-center justify-end gap-1">
            <button class="remove-food p-1 rounded hover:bg-accent-red/10 text-text-muted hover:text-accent-red transition-colors" title="Sil">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        </div>
      `;
    }

    function createMealCard(mealIdx) {
      const mealName = defaultMeals[mealIdx] || `Öğün ${mealIdx + 1}`;
      const emojis = { 'Kahvaltı': '🌅', 'Öğle Yemeği': '☀️', 'Akşam Yemeği': '🌙' };
      const emoji = emojis[mealName] || '🍎';
      
      const div = document.createElement('div');
      div.className = 'card meal-card';
      div.dataset.meal = mealIdx;
      div.innerHTML = `
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">${emoji}</span>
            <input type="text" value="${mealName}" class="meal-name text-lg font-semibold text-text-primary bg-transparent border-none outline-none focus:ring-0 w-[200px]" />
          </div>
          <div class="flex items-center gap-2">
            <span class="meal-kcal text-xs font-semibold text-accent-green bg-accent-green/10 px-2 py-1 rounded-full">0 kcal</span>
            <button class="remove-meal p-2 rounded-lg hover:bg-accent-red/10 text-text-muted hover:text-accent-red transition-all" title="Öğünü Sil">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </button>
          </div>
        </div>

        <!-- Column Headers -->
        <div class="hidden sm:grid grid-cols-12 gap-2 px-3 mb-2 text-[10px] font-semibold text-text-muted uppercase tracking-wider">
          <div class="col-span-3">Besin</div>
          <div class="col-span-1 text-center">Miktar</div>
          <div class="col-span-1 text-center">Birim</div>
          <div class="col-span-1 text-center">Kalori</div>
          <div class="col-span-2 text-center">Protein (g)</div>
          <div class="col-span-2 text-center">Karb (g)</div>
          <div class="col-span-1 text-center">Yağ (g)</div>
          <div class="col-span-1"></div>
        </div>

        <div class="foods-container space-y-2">
          ${createFoodRow()}
        </div>

        <button class="add-food-btn w-full mt-3 py-2.5 border border-dashed border-border-default rounded-lg text-text-muted hover:text-accent-cyan hover:border-accent-cyan transition-all flex items-center justify-center gap-2 text-xs font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Besin Ekle
        </button>
      `;
      return div;
    }

    function addMeal() {
      const container = document.getElementById('mealsContainer');
      const card = createMealCard(mealCounter);
      container.appendChild(card);
      mealCounter++;
      bindMealEvents(card);
      updateSaveBtn();
    }

    function bindMealEvents(card) {
      card.querySelector('.remove-meal').addEventListener('click', () => {
        card.remove();
        updateSaveBtn();
      });

      card.querySelector('.add-food-btn').addEventListener('click', () => {
        const container = card.querySelector('.foods-container');
        container.insertAdjacentHTML('beforeend', createFoodRow());
        bindFoodEvents(card);
        updateMealKcal(card);
      });

      bindFoodEvents(card);
    }

    function bindFoodEvents(card) {
      const container = card.querySelector('.foods-container');
      
      container.querySelectorAll('.remove-food').forEach(btn => {
        btn.onclick = () => {
          const rows = container.querySelectorAll('.food-row');
          if (rows.length > 1) {
            btn.closest('.food-row').remove();
            updateMealKcal(card);
            updateSaveBtn();
          }
        };
      });

      container.querySelectorAll('input').forEach(input => {
        input.addEventListener('input', () => {
          updateMealKcal(card);
          updateSaveBtn();
        });
      });
    }

    function updateMealKcal(card) {
      let total = 0;
      card.querySelectorAll('.food-calories').forEach(input => {
        total += parseInt(input.value) || 0;
      });
      card.querySelector('.meal-kcal').textContent = `${total} kcal`;
    }

    function updateMacroCalc() {
      const p = parseInt(document.getElementById('proteinTarget').value) || 0;
      const c = parseInt(document.getElementById('carbsTarget').value) || 0;
      const f = parseInt(document.getElementById('fatTarget').value) || 0;
      const calc = (p * 4) + (c * 4) + (f * 9);
      document.getElementById('calcCalories').textContent = calc;
    }

    function updateSaveBtn() {
      const name = document.getElementById('dietName').value.trim();
      const mealCards = document.querySelectorAll('.meal-card');
      let hasFood = false;
      
      mealCards.forEach(card => {
        card.querySelectorAll('.food-name').forEach(input => {
          if (input.value.trim()) hasFood = true;
        });
      });

      document.getElementById('saveBtn').disabled = !(name && mealCards.length > 0 && hasFood);
    }

    document.getElementById('dietName').addEventListener('input', updateSaveBtn);
    ['proteinTarget', 'carbsTarget', 'fatTarget'].forEach(id => {
      document.getElementById(id).addEventListener('input', updateMacroCalc);
    });

    document.getElementById('addMealBtn').addEventListener('click', addMeal);

    // Save button
    document.getElementById('saveBtn').addEventListener('click', async () => {
      const btn = document.getElementById('saveBtn');
      const statusMsg = document.getElementById('statusMsg');
      
      btn.disabled = true;
      btn.innerHTML = '<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Kaydediliyor...';

      const mealsData = [];
      document.querySelectorAll('.meal-card').forEach((card, mealIdx) => {
        const mealName = card.querySelector('.meal-name').value.trim() || `Öğün ${mealIdx + 1}`;
        const foods = [];
        
        card.querySelectorAll('.food-row').forEach(row => {
          const name = row.querySelector('.food-name').value.trim();
          if (!name) return;
          
          foods.push({
            name,
            amount: parseFloat(row.querySelector('.food-amount').value) || 100,
            unit: row.querySelector('.food-unit').value || 'g',
            calories: parseInt(row.querySelector('.food-calories').value) || 0,
            protein: parseFloat(row.querySelector('.food-protein').value) || 0,
            carbs: parseFloat(row.querySelector('.food-carbs').value) || 0,
            fat: parseFloat(row.querySelector('.food-fat').value) || 0,
          });
        });

        if (foods.length > 0) {
          mealsData.push({ name: mealName, order: mealIdx, foods });
        }
      });

      try {
        const res = await fetch('/api/diet', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            studentId: studentId,
            name: document.getElementById('dietName').value.trim(),
            dailyCalorieTarget: parseInt(document.getElementById('calorieTarget').value) || 2000,
            proteinTarget: parseInt(document.getElementById('proteinTarget').value) || 150,
            carbsTarget: parseInt(document.getElementById('carbsTarget').value) || 200,
            fatTarget: parseInt(document.getElementById('fatTarget').value) || 70,
            waterTarget: parseInt(document.getElementById('waterTarget').value) || 3000,
            meals: mealsData,
          }),
        });

        if (res.ok) {
          statusMsg.className = 'mt-6 p-4 rounded-xl text-sm bg-accent-green/10 border border-accent-green/20 text-accent-green';
          statusMsg.textContent = 'Diyet planı başarıyla oluşturuldu! Yönlendiriliyorsunuz...';
          statusMsg.classList.remove('hidden');
          setTimeout(() => {
            window.location.href = `/students/${studentId}`;
          }, 1500);
        } else {
          const err = await res.json();
          throw new Error(err.error || 'Bir hata oluştu');
        }
      } catch (e) {
        statusMsg.className = 'mt-6 p-4 rounded-xl text-sm bg-accent-red/10 border border-accent-red/20 text-accent-red';
        statusMsg.textContent = e.message;
        statusMsg.classList.remove('hidden');
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Diyeti Kaydet';
      }
    });

    // Start with default meals (Kahvaltı, Öğle, Akşam)
    addMeal(); // Kahvaltı
    addMeal(); // Ara Öğün 1
    addMeal(); // Öğle Yemeği
    addMeal(); // Ara Öğün 2
    addMeal(); // Akşam Yemeği
    
    updateMacroCalc();
  </script>
</MainLayout>
