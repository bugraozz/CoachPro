---
import MainLayout from '../../layouts/MainLayout.astro';
import AdminUsersPanel from '../../components/dashboard/AdminUsersPanel';
import { canManageAdminSecurity, getUserFromRequest, isBackofficeUser, isSuperAdmin } from '../../lib/auth';
import prisma from '../../lib/prisma';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (!isBackofficeUser(user)) {
  return Astro.redirect('/dashboard');
}

const currentUser = user as NonNullable<typeof user>;
const canManageSensitiveMutations = canManageAdminSecurity(currentUser);
const canManageMembershipMutations = true;
const prismaClient = prisma as any;

const ok = (Astro.url.searchParams.get('ok') || '').trim();
const error = (Astro.url.searchParams.get('error') || '').trim();

type AdminAuditPayload = {
  action: string;
  targetUserId?: string | null;
  targetEmail?: string | null;
  metadata?: Record<string, unknown>;
};

function getRequestIp(request: Request): string {
  const forwardedFor = request.headers.get('x-forwarded-for');
  if (forwardedFor) {
    const firstIp = forwardedFor.split(',')[0]?.trim();
    if (firstIp) {
      return firstIp;
    }
  }

  const realIp = request.headers.get('x-real-ip');
  if (realIp) {
    return realIp;
  }

  return 'unknown';
}

async function writeAdminAuditLog(payload: AdminAuditPayload): Promise<void> {
  try {
    await prismaClient.adminActionAudit.create({
      data: {
        action: payload.action,
        adminUserId: currentUser.id,
        adminEmail: currentUser.email || null,
        targetUserId: payload.targetUserId || null,
        targetEmail: payload.targetEmail || null,
        metadata: {
          ...(payload.metadata || {}),
          ip: getRequestIp(Astro.request),
          userAgent: Astro.request.headers.get('user-agent') || null,
          requestPath: Astro.url.pathname,
        },
      },
    });
  } catch (auditError) {
    console.error('Admin audit log write failed:', auditError);
  }
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('action') || '').trim();

  try {
    if (action === 'toggle_user_active') {
      if (!canManageSensitiveMutations) {
        throw new Error('Bu islemi sadece super admin yapabilir.');
      }

      const targetUserId = String(formData.get('userId') || '').trim();
      const nextState = String(formData.get('nextState') || '').trim() === '1';

      if (!targetUserId) {
        throw new Error('Kullanici secilemedi.');
      }

      if (targetUserId === currentUser.id && !nextState) {
        throw new Error('Kendi admin hesabinizi pasif yapamazsiniz.');
      }

      const targetUser = await prisma.user.findFirst({
        where: { id: targetUserId },
        select: {
          id: true,
          email: true,
          role: true,
          active: true,
        },
      });

      if (!targetUser) {
        throw new Error('Kullanici bulunamadi.');
      }

      const updated = await prisma.user.updateMany({
        where: {
          id: targetUserId,
          role: 'student',
        },
        data: { active: nextState },
      });

      if (!updated.count) {
        throw new Error('Sadece ogrenci hesaplari bu sayfadan degistirilebilir.');
      }

      await writeAdminAuditLog({
        action,
        targetUserId: targetUser.id,
        targetEmail: targetUser.email,
        metadata: {
          role: targetUser.role,
          previousActive: targetUser.active,
          nextActive: nextState,
          sourceModule: 'admin-users',
        },
      });

      return Astro.redirect('/admin/users?ok=user-updated');
    }

    if (
      action === 'extend_student_membership'
      || action === 'gift_student_membership'
      || action === 'update_student_membership'
    ) {
      if (!canManageMembershipMutations) {
        throw new Error('Bu islemi yapmaya yetkiniz yok.');
      }

      const membershipType = action === 'update_student_membership'
        ? String(formData.get('membershipType') || '').trim()
        : action === 'gift_student_membership'
          ? 'gift'
          : 'extend';

      const targetUserId = String(formData.get('userId') || '').trim();
      const daysRaw = parseInt(String(formData.get('days') || '30').trim(), 10);
      const days = Number.isNaN(daysRaw) ? -1 : Math.min(36500, Math.max(1, daysRaw));

      if (!targetUserId) {
        throw new Error('Ogrenci secilemedi.');
      }

      if (membershipType !== 'extend' && membershipType !== 'gift') {
        throw new Error('Gecersiz uyelik islem tipi.');
      }

      if (days <= 0) {
        throw new Error('Gecersiz sure.');
      }

      const targetUser = await prisma.user.findFirst({
        where: { id: targetUserId, role: 'student' },
        select: {
          id: true,
          email: true,
          role: true,
          active: true,
          studentPaymentStatus: true,
          studentAccessEnd: true,
          studentPaidAt: true,
        },
      });

      if (!targetUser) {
        throw new Error('Ogrenci bulunamadi.');
      }

      const now = new Date();
      const baseAccessDate = targetUser.studentAccessEnd && new Date(targetUser.studentAccessEnd) > now
        ? new Date(targetUser.studentAccessEnd)
        : now;

      const nextAccessEnd = new Date(baseAccessDate);
      nextAccessEnd.setDate(nextAccessEnd.getDate() + days);

      await prisma.user.update({
        where: { id: targetUserId },
        data: {
          active: true,
          studentPaymentStatus: 'paid',
          studentPaidAt: targetUser.studentPaidAt || now,
          studentAccessEnd: nextAccessEnd,
        },
      });

      await writeAdminAuditLog({
        action: membershipType === 'gift' ? 'gift_student_membership' : 'extend_student_membership',
        targetUserId: targetUser.id,
        targetEmail: targetUser.email,
        metadata: {
          previousActive: targetUser.active,
          previousStudentPaymentStatus: targetUser.studentPaymentStatus || null,
          previousStudentAccessEnd: targetUser.studentAccessEnd ? targetUser.studentAccessEnd.toISOString() : null,
          nextStudentPaymentStatus: 'paid',
          nextStudentAccessEnd: nextAccessEnd.toISOString(),
          extensionDays: days,
          sourceModule: 'admin-users',
        },
      });

      if (membershipType === 'gift') {
        return Astro.redirect('/admin/users?ok=student-membership-gifted');
      }

      return Astro.redirect('/admin/users?ok=student-membership-extended');
    }
  } catch (postError) {
    const message = postError instanceof Error ? postError.message : 'Islem tamamlanamadi.';
    return Astro.redirect(`/admin/users?error=${encodeURIComponent(message)}`);
  }

  return Astro.redirect('/admin/users');
}

const students = await prisma.user.findMany({
  where: { role: 'student' },
  select: {
    id: true,
    name: true,
    email: true,
    active: true,
    createdAt: true,
    studentPaymentStatus: true,
    studentAccessEnd: true,
    coach: {
      select: {
        id: true,
        name: true,
      },
    },
  },
  orderBy: { createdAt: 'desc' },
  take: 500,
});

const totalStudents = students.length;
const activeStudents = students.filter((student) => student.active).length;
const passiveStudents = totalStudents - activeStudents;
const paidStudents = students.filter((student) => student.studentPaymentStatus === 'paid').length;
const pendingStudents = totalStudents - paidStudents;
---

<MainLayout title="Admin Kullanici Yonetimi" activePage="admin-users">
  <AdminUsersPanel
    client:load
    ok={ok}
    error={error}
    isSuperAdmin={isSuperAdmin(currentUser)}
    canManageSensitive={canManageSensitiveMutations}
    canManageMembership={canManageMembershipMutations}
    totalStudents={totalStudents}
    activeStudents={activeStudents}
    passiveStudents={passiveStudents}
    paidStudents={paidStudents}
    pendingStudents={pendingStudents}
    students={students.map((s) => ({
      id: s.id,
      name: s.name,
      email: s.email,
      active: s.active,
      createdAt: s.createdAt.toISOString(),
      studentPaymentStatus: s.studentPaymentStatus,
      studentAccessEnd: s.studentAccessEnd ? s.studentAccessEnd.toISOString() : null,
      coach: s.coach ? { id: s.coach.id, name: s.coach.name } : null,
    }))}
  />
</MainLayout>
