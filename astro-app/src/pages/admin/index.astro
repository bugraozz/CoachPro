---
import MainLayout from '../../layouts/MainLayout.astro';
import AdminDashboardPanel from '../../components/dashboard/AdminDashboardPanel';
import { getUserFromRequest, isBackofficeUser } from '../../lib/auth';
import prisma from '../../lib/prisma';
import {
  DEFAULT_MAINTENANCE_MESSAGE,
  getMaintenanceModeStatus,
  setMaintenanceModeStatus,
} from '../../lib/system-settings';

const user = await getUserFromRequest(Astro.request);

if (!user) {
  return Astro.redirect('/auth/login');
}

if (!isBackofficeUser(user)) {
  return Astro.redirect('/dashboard');
}

const adminUser = user as NonNullable<typeof user>;
const prismaClient = prisma as any;

const ok = String(Astro.url.searchParams.get('ok') || '').trim();
const error = String(Astro.url.searchParams.get('error') || '').trim();

function getRequestIp(request: Request): string {
  const forwardedFor = request.headers.get('x-forwarded-for');
  if (forwardedFor) {
    const firstIp = forwardedFor.split(',')[0]?.trim();
    if (firstIp) {
      return firstIp;
    }
  }

  const realIp = request.headers.get('x-real-ip');
  if (realIp) {
    return realIp;
  }

  return 'unknown';
}

async function writeAdminAuditLog(payload: {
  action: string;
  metadata?: Record<string, unknown>;
}): Promise<void> {
  try {
    await prismaClient.adminActionAudit.create({
      data: {
        action: payload.action,
        adminUserId: adminUser.id,
        adminEmail: adminUser.email || null,
        metadata: {
          ...(payload.metadata || {}),
          ip: getRequestIp(Astro.request),
          userAgent: Astro.request.headers.get('user-agent') || null,
          requestPath: Astro.url.pathname,
        },
      },
    });
  } catch (auditError) {
    console.error('Admin dashboard audit log write failed:', auditError);
  }
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('action') || '').trim();

  try {
    if (action === 'toggle_maintenance_mode') {
      const enabled = String(formData.get('enabled') || '').trim() === 'true';
      const message = String(formData.get('message') || '').trim() || DEFAULT_MAINTENANCE_MESSAGE;

      await setMaintenanceModeStatus({
        enabled,
        message,
        updatedBy: adminUser.id,
      });

      await writeAdminAuditLog({
        action,
        metadata: {
          enabled,
          message,
        },
      });

      return Astro.redirect(`/admin?ok=maintenance-${enabled ? 'enabled' : 'disabled'}`);
    }
  } catch (postError) {
    const message = postError instanceof Error ? postError.message : 'Islem tamamlanamadi.';
    return Astro.redirect(`/admin?error=${encodeURIComponent(message)}`);
  }
}

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);

const sevenDaysAgo = new Date(now);
sevenDaysAgo.setDate(now.getDate() - 7);

const sixMonthsStart = new Date(now.getFullYear(), now.getMonth() - 5, 1);

const last14DaysStart = new Date(now);
last14DaysStart.setHours(0, 0, 0, 0);
last14DaysStart.setDate(last14DaysStart.getDate() - 13);

const [
  totalUsers,
  totalCoaches,
  totalStudents,
  monthRevenueTransactions,
  newUsersLast7Days,
  maintenanceMode,
  paidTransactionsForChart,
  recentUsersForChart,
] = await Promise.all([
  prisma.user.count(),
  prisma.user.count({ where: { role: 'coach' } }),
  prisma.user.count({ where: { role: 'student' } }),
  prisma.paymentTransaction.findMany({
    where: {
      status: 'paid',
      OR: [
        { paidAt: { gte: monthStart } },
        {
          paidAt: null,
          createdAt: { gte: monthStart },
        },
      ],
    },
    select: {
      amount: true,
    },
  }),
  prisma.user.count({
    where: {
      createdAt: { gte: sevenDaysAgo },
    },
  }),
  getMaintenanceModeStatus(),
  prisma.paymentTransaction.findMany({
    where: {
      status: 'paid',
      OR: [
        { paidAt: { gte: sixMonthsStart } },
        {
          paidAt: null,
          createdAt: { gte: sixMonthsStart },
        },
      ],
    },
    select: {
      amount: true,
      paidAt: true,
      createdAt: true,
    },
    orderBy: { createdAt: 'asc' },
  }),
  prisma.user.findMany({
    where: {
      createdAt: { gte: last14DaysStart },
    },
    select: {
      createdAt: true,
      role: true,
    },
    orderBy: { createdAt: 'asc' },
  }),
]);

const monthRevenue = monthRevenueTransactions.reduce((sum, transaction) => sum + Number(transaction.amount || 0), 0);

const salesMonthKeys: string[] = [];
const salesMonthLabels: string[] = [];
for (let i = 5; i >= 0; i -= 1) {
  const monthDate = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const key = `${monthDate.getFullYear()}-${String(monthDate.getMonth() + 1).padStart(2, '0')}`;

  salesMonthKeys.push(key);
  salesMonthLabels.push(monthDate.toLocaleDateString('tr-TR', { month: 'short' }));
}

const revenueByMonth = new Map<string, number>(salesMonthKeys.map((key) => [key, 0]));
const transactionsByMonth = new Map<string, number>(salesMonthKeys.map((key) => [key, 0]));

for (const tx of paidTransactionsForChart) {
  const txDate = tx.paidAt ? new Date(tx.paidAt) : new Date(tx.createdAt);
  const key = `${txDate.getFullYear()}-${String(txDate.getMonth() + 1).padStart(2, '0')}`;
  if (!revenueByMonth.has(key)) {
    continue;
  }

  revenueByMonth.set(key, (revenueByMonth.get(key) || 0) + Number(tx.amount || 0));
  transactionsByMonth.set(key, (transactionsByMonth.get(key) || 0) + 1);
}

const salesRevenueSeries = salesMonthKeys.map((key) => Math.round(revenueByMonth.get(key) || 0));
const salesTransactionSeries = salesMonthKeys.map((key) => transactionsByMonth.get(key) || 0);
const averageMonthlyRevenue = salesRevenueSeries.length > 0
  ? Math.round(salesRevenueSeries.reduce((sum, value) => sum + value, 0) / salesRevenueSeries.length)
  : 0;

function toDayKey(dateValue: Date): string {
  const year = dateValue.getFullYear();
  const month = String(dateValue.getMonth() + 1).padStart(2, '0');
  const day = String(dateValue.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

const registrationDayKeys: string[] = [];
const registrationDayLabels: string[] = [];
for (let i = 13; i >= 0; i -= 1) {
  const dayDate = new Date(last14DaysStart);
  dayDate.setDate(last14DaysStart.getDate() + (13 - i));

  registrationDayKeys.push(toDayKey(dayDate));
  registrationDayLabels.push(dayDate.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit' }));
}

const totalRegistrationsByDay = new Map<string, number>(registrationDayKeys.map((key) => [key, 0]));
const coachRegistrationsByDay = new Map<string, number>(registrationDayKeys.map((key) => [key, 0]));
const studentRegistrationsByDay = new Map<string, number>(registrationDayKeys.map((key) => [key, 0]));

for (const account of recentUsersForChart) {
  const key = toDayKey(new Date(account.createdAt));
  if (!totalRegistrationsByDay.has(key)) {
    continue;
  }

  totalRegistrationsByDay.set(key, (totalRegistrationsByDay.get(key) || 0) + 1);

  if (account.role === 'coach') {
    coachRegistrationsByDay.set(key, (coachRegistrationsByDay.get(key) || 0) + 1);
  }

  if (account.role === 'student') {
    studentRegistrationsByDay.set(key, (studentRegistrationsByDay.get(key) || 0) + 1);
  }
}

const registrationTotalSeries = registrationDayKeys.map((key) => totalRegistrationsByDay.get(key) || 0);
const registrationCoachSeries = registrationDayKeys.map((key) => coachRegistrationsByDay.get(key) || 0);
const registrationStudentSeries = registrationDayKeys.map((key) => studentRegistrationsByDay.get(key) || 0);

const registrationsLast14Days = registrationTotalSeries.reduce((sum, value) => sum + value, 0);
const coachRegistrationsLast14Days = registrationCoachSeries.reduce((sum, value) => sum + value, 0);
const studentRegistrationsLast14Days = registrationStudentSeries.reduce((sum, value) => sum + value, 0);

const salesData = salesMonthLabels.map((month, index) => ({
  month,
  revenue: salesRevenueSeries[index] || 0,
  transactions: salesTransactionSeries[index] || 0,
}));

const registrationData = registrationDayLabels.map((day, index) => ({
  day,
  total: registrationTotalSeries[index] || 0,
  coaches: registrationCoachSeries[index] || 0,
  students: registrationStudentSeries[index] || 0,
}));
---

<MainLayout title="Admin Dashboard" activePage="admin">
  <AdminDashboardPanel
    client:load
    ok={ok}
    error={error}
    totalUsers={totalUsers}
    totalCoaches={totalCoaches}
    totalStudents={totalStudents}
    monthRevenue={monthRevenue}
    averageMonthlyRevenue={averageMonthlyRevenue}
    newUsersLast7Days={newUsersLast7Days}
    registrationsLast14Days={registrationsLast14Days}
    coachRegistrationsLast14Days={coachRegistrationsLast14Days}
    studentRegistrationsLast14Days={studentRegistrationsLast14Days}
    salesData={salesData}
    registrationData={registrationData}
    maintenanceMode={{
      enabled: maintenanceMode.enabled,
      message: maintenanceMode.message,
      updatedAt: maintenanceMode.updatedAt,
    }}
    defaultMaintenanceMessage={DEFAULT_MAINTENANCE_MESSAGE}
  />
</MainLayout>
