---
import { getHomeTextOverrides } from '../lib/site-content';
import PublicLayout from '../layouts/PublicLayout.astro';

const textOverrides = await getHomeTextOverrides();

const pageText = (key: string, fallback: string): string => {
  const value = textOverrides[key];
  if (typeof value !== 'string') {
    return fallback;
  }

  const normalized = value.trim();
  return normalized || fallback;
};
---

<PublicLayout
  title="CoachPro - Iletisim"
  description="CoachPro iletisim sayfasi"
  bodyClass="min-h-screen bg-bg-primary"
>
  <header class="border-b border-border-default bg-white/90 backdrop-blur-xl sticky top-0 z-40">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-bold text-xl text-text-primary">CoachPro</a>
      <div class="flex items-center gap-4 text-sm">
        <a href="/about" class="text-text-secondary hover:text-text-primary transition-colors">About</a>
        <a href="/faq" class="text-text-secondary hover:text-text-primary transition-colors">FAQ</a>
        <a href="/auth/register" class="btn-primary">Ucretsiz Basla</a>
      </div>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-6 py-14 space-y-10">
    <section class="text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-50 border border-red-200 text-red-600 text-xs font-semibold mb-4">
        ILETISIM
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">Bizimle Iletisime Gecin</h1>
      <p class="text-text-secondary max-w-2xl mx-auto leading-relaxed">
        Urun, abonelik, teknik destek veya is birligi konularinda bize ulasabilirsiniz.
        En hizli donus icin konu basligini net yazarak e-posta gondermenizi oneririz.
      </p>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <article class="card">
        <h2 class="text-xl font-semibold text-text-primary mb-2">Genel Destek</h2>
        <p class="text-sm text-text-secondary mb-4">Hesap, odeme ve panel kullanim sorulari.</p>
        <a href="mailto:destek@coachpro.app" class="btn-secondary inline-flex">destek@coachpro.app</a>
      </article>

      <article class="card">
        <h2 class="text-xl font-semibold text-text-primary mb-2">Teknik Sorunlar</h2>
        <p class="text-sm text-text-secondary mb-4">Hata raporu, performans veya erisim problemleri.</p>
        <a href="mailto:tech@coachpro.app" class="btn-secondary inline-flex">tech@coachpro.app</a>
      </article>

      <article class="card">
        <h2 class="text-xl font-semibold text-text-primary mb-2">Is Birligi</h2>
        <p class="text-sm text-text-secondary mb-4">Kurum, partnerlik ve entegrasyon talepleri.</p>
        <a href="mailto:partner@coachpro.app" class="btn-secondary inline-flex">partner@coachpro.app</a>
      </article>
    </section>

    <section class="card">
      <div class="mb-5">
        <h2 class="text-2xl font-semibold text-text-primary mb-2">Iletisim Formu</h2>
        <p class="text-sm text-text-secondary">Mesajinizi dogrudan panel uzerinden gonderebilirsiniz. Tum alanlar zorunludur.</p>
      </div>

      <form id="contactForm" class="space-y-4" novalidate>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="label block mb-2" for="contact-name">Ad Soyad</label>
            <input id="contact-name" name="name" type="text" class="input-field" minlength="2" maxlength="80" required />
          </div>

          <div>
            <label class="label block mb-2" for="contact-email">E-posta</label>
            <input id="contact-email" name="email" type="email" class="input-field" maxlength="160" required />
          </div>
        </div>

        <div>
          <label class="label block mb-2" for="contact-subject">Konu</label>
          <input id="contact-subject" name="subject" type="text" class="input-field" minlength="3" maxlength="140" required />
        </div>

        <div>
          <label class="label block mb-2" for="contact-message">Mesaj</label>
          <textarea id="contact-message" name="message" rows="6" class="input-field resize-y" minlength="10" maxlength="2500" required></textarea>
        </div>

        <div class="hidden" aria-hidden="true">
          <label for="contact-website">Website</label>
          <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <input id="contact-submitted-at" name="submittedAt" type="hidden" value="" />

        <div class="flex flex-col sm:flex-row sm:items-center gap-3">
          <button id="contact-submit-button" type="submit" class="btn-primary px-8 py-3 inline-flex items-center justify-center">
            Mesaji Gonder
          </button>
          <p id="contact-form-status" class="text-sm text-text-muted" role="status" aria-live="polite"></p>
        </div>
      </form>
    </section>

    <section class="card">
      <h2 class="text-2xl font-semibold text-text-primary mb-3">Yanit Sureleri</h2>
      <ul class="space-y-2 text-text-secondary">
        <li>Genel destek talepleri: 1 is gunu icinde.</li>
        <li>Teknik kritik sorunlar: oncelikli olarak ayni gun icinde.</li>
        <li>Is birligi talepleri: 2-3 is gunu icinde.</li>
      </ul>
    </section>

    <section class="text-center">
      <p class="text-text-secondary mb-4">Sik sorulan sorular icin yardim merkezine de goz atabilirsiniz.</p>
      <a href="/faq" class="btn-primary px-8 py-3 inline-flex items-center justify-center">FAQ Sayfasina Git</a>
    </section>
  </main>

  <footer class="py-10 px-6 border-t border-border-default bg-white/80">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-secondary">
      <span>{pageText('footer.copyright', '© 2024 CoachPro. Tum haklari saklidir.')}</span>
      <div class="flex items-center gap-5">
        <a href="/privacy" class="hover:text-text-primary transition-colors">{pageText('footer.link.privacy', 'Gizlilik')}</a>
        <a href="/terms" class="hover:text-text-primary transition-colors">{pageText('footer.link.terms', 'Kullanim Sartlari')}</a>
        <a href="/contact" class="hover:text-text-primary transition-colors">{pageText('footer.link.contact', 'Iletisim')}</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    const form = document.getElementById('contactForm');
    const submitButton = document.getElementById('contact-submit-button');
    const statusNode = document.getElementById('contact-form-status');
    const submittedAtNode = document.getElementById('contact-submitted-at');

    if (submittedAtNode instanceof HTMLInputElement) {
      submittedAtNode.value = new Date().toISOString();
    }

    function setStatus(message, tone) {
      if (!(statusNode instanceof HTMLElement)) {
        return;
      }

      statusNode.textContent = message;
      statusNode.classList.remove('text-text-muted', 'text-accent-green', 'text-accent-red');

      if (tone === 'success') {
        statusNode.classList.add('text-accent-green');
      } else if (tone === 'error') {
        statusNode.classList.add('text-accent-red');
      } else {
        statusNode.classList.add('text-text-muted');
      }
    }

    if (form instanceof HTMLFormElement) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!(submitButton instanceof HTMLButtonElement)) {
          return;
        }

        const formData = new FormData(form);

        const payload = {
          name: String(formData.get('name') || '').trim(),
          email: String(formData.get('email') || '').trim(),
          subject: String(formData.get('subject') || '').trim(),
          message: String(formData.get('message') || '').trim(),
          website: String(formData.get('website') || '').trim(),
          submittedAt: String(formData.get('submittedAt') || '').trim(),
        };

        if (!payload.name || !payload.email || !payload.subject || !payload.message) {
          setStatus('Lutfen tum zorunlu alanlari doldurun.', 'error');
          return;
        }

        submitButton.disabled = true;
        setStatus('Mesajiniz gonderiliyor...', 'neutral');

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(payload),
          });

          const result = await response.json().catch(() => null);

          if (!response.ok) {
            const errorMessage = result && typeof result.error === 'string'
              ? result.error
              : 'Mesajiniz su anda gonderilemedi.';
            setStatus(errorMessage, 'error');
            return;
          }

          form.reset();
          if (submittedAtNode instanceof HTMLInputElement) {
            submittedAtNode.value = new Date().toISOString();
          }
          setStatus('Tesekkurler. Mesajiniz alindi, en kisa surede donus yapacagiz.', 'success');
        } catch {
          setStatus('Baglanti hatasi olustu. Lutfen tekrar deneyin.', 'error');
        } finally {
          submitButton.disabled = false;
        }
      });
    }
  </script>
</PublicLayout>
