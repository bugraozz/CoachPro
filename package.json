{
	"name": "coach-workspace",
	"private": true,
	"scripts": {
		"dev": "npm --prefix astro-app run dev --",
		"dev:web": "npm --prefix astro-app run dev -- --host 0.0.0.0",
		"dev:mobile": "npm --prefix coach-mobile run start -- --clear --port 8082",
		"dev:all": "node scripts/dev-all.mjs",
		"dev:host": "npm --prefix astro-app run dev -- --host",
		"build": "npm --prefix astro-app run build",
		"preview": "npm --prefix astro-app run preview",
		"db:generate": "npm --prefix astro-app run db:generate",
		"db:push": "npm --prefix astro-app run db:push",
		"docker:up": "docker compose up",
		"docker:up:detached": "docker compose up -d",
		"docker:up:build": "docker compose up --build",
		"docker:up:base": "docker compose -f docker-compose.yml up --build",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"security:smoke": "node astro-app/scripts/security-smoke.mjs",
		"security:audit": "node astro-app/scripts/full-security-audit.mjs",
		"security:policy": "node astro-app/scripts/security-policy-check.mjs",
		"mobile:smoke": "node astro-app/scripts/mobile-smoke.mjs",
		"admin:bootstrap": "node astro-app/scripts/bootstrap-super-admin.mjs",
		"payments:contract": "node astro-app/scripts/payments-contract-e2e.mjs",
		"quality:smoke": "node astro-app/scripts/quality-smoke.mjs",
		"quality:gate": "npm run quality:smoke && npm run payments:contract"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.8",
		"typescript": "^6.0.2"
	}
}
